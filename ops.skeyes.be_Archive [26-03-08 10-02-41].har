            "text": "// OPENLAYERS PART\n\nvar zoomLowLimit = 4;\nvar zoomUpLimit = 12;\nvar bounds = new OpenLayers.Bounds(\n\t// Europe mesoscale model\n\t-1892431.34, 5465442.18,\n\t1558472.87, 9100250.90\n);\nvar aerodromeFeatureType = \"stations_ws_permit_mesoscale\";\nvar meteograms;\nvar isCustomOptionsActive = false;\nvar usucode;\n\nfunction init() {\n\tinit_commons();\n\t\n\t// meteogram layer style\n\tvar meteograms_style;\n\tif (isMobile) {\n\t\tmeteograms_style = new OpenLayers.Style({\n\t\t\t'pointRadius' : \"${radius}\",\n\t\t\t'fillColor' : '#1793d7',\n\t\t\t'fillOpacity' : 1,\n\t\t\t'stroke' : false,\n\t\t\t'label' : '${usucode}',\n\t\t\t'fontColor' : '#234f96',\n\t\t\t'labelSelect' : true\n\t\t},{\n\t\t\tcontext : {\n\t\t\t\tradius: function() {\n\t\t\t\t\tvar radius_factor = 7-(Math.round(Math.floor(arguments[0].layer.map.getResolution()/600)));\n\t\t\t\t\tif (radius_factor < 1) { \n\t\t\t\t\t\tradius_factor = 1;\n\t\t\t\t\t} \n\t\t\t\t\tmeteograms_style.defaultStyle.fontSize = 2*radius_factor;\n\t\t\t\t\tmeteograms_style.defaultStyle.labelYOffset = -2*radius_factor;\n\t\t\t\t\treturn radius_factor;\n\t\t\t\t}\n\t        }\n\t\t});\t\t\n\t} else {\n\t\tmeteograms_style = new OpenLayers.Style({\n\t\t\t'pointRadius' : \"${radius}\",\n\t\t\t'fillColor' : '#1793d7',\n\t\t\t'fillOpacity' : 1,\n\t\t\t'stroke' : false\n\t\t},{\n\t\t\tcontext : {\n\t\t\t\tradius: function() {\n\t\t\t\t\tvar radius_factor = 7-(Math.round(Math.floor(arguments[0].layer.map.getResolution()/600)));\n\t\t\t\t\tif (radius_factor < 1) { \n\t\t\t\t\t\tradius_factor = 1;\n\t\t\t\t\t} \n\t\t\t\t\treturn radius_factor;\n\t\t\t\t}\n            }\n\t\t});\t\t\n\t}\n\t\t\n\tvar meteograms_style_selected = new OpenLayers.Style({\n\t\t'pointRadius': 10,\n\t\t'graphicZIndex': 15\n\t});\t\n\tvar meteograms_style_map = new OpenLayers.StyleMap({\n\t\t'default': meteograms_style,\n\t\t'select': meteograms_style_selected\n\t});\n\t\n\t// meteogram layer\n\tmeteograms = new OpenLayers.Layer.Vector(\"meteograms\", {\n\t\tstrategies: [new OpenLayers.Strategy.BBOX()],\n\t\tprotocol: new OpenLayers.Protocol.WFS({\n\t\t\tversion: \"1.1.0\",\n\t\t\tsrsName: \"EPSG:900913\",\n\t\t\turl:  geoserver+\"wfs\",\n\t\t\tfeatureType: \"meteograms\",\n\t\t\tfeaturePrefix: workspace_meteo,\n\t\t\tgeometryName: 'geom'\n\t\t}),\n\t\tstyleMap: meteograms_style_map,\n\t\tdisplayInLayerSwitcher: false,\n\t\trendererOptions: { zIndexing: true }\n\t});\t\n\tmap.addLayer(meteograms);\n\t\n\t// meteogram control : not for smartphone and tablet\n\tif (!isMobile) {\n\t\tvar meteograms_ctrl = new OpenLayers.Control.SelectFeature (\n\t\t\tmeteograms,\n\t\t\t{\n\t\t\t\thover: true,\n\t\t\t\tonSelect: onSelectGramStation,\n\t\t\t\tonUnselect: onUnSelectGramStation\n\t\t\t}\n\t\t);\n\t} else {\n\t\tvar meteograms_ctrl = new OpenLayers.Control.SelectFeature (\n\t\t\t\tmeteograms,\n\t\t\t\t{\n\t\t\t\t\tonSelect: onSelectGramStationMobile\n\t\t\t\t}\n\t\t\t);\t\t\n\t}\n\tmap.addControl(meteograms_ctrl);\n\tmeteograms_ctrl.activate();\n\t\n\t// default aerodromes layer visibility\n\taerodromes.setVisibility(false);\n\t\n\t// map click event control\n\t//map.events.register('click', map, sendCustomPointRequest);\n\t\n\t// default visibility for overlay layers\n\tsetClassDivVis('dataLbl','hidden');\n\tsetClassDivVis('dataLayersDiv','hidden');\n}\n\n// ol map functions\nfunction onSelectAerodrome(feature) {\n\t/*setLegend(feature);\n\taerodromes.events.register(\"click\", aerodromes, sendCustomAerodromeRequest);*/\n}\n\nfunction onUnselectAerodrome(feature) {\n\t/*resetLegend(feature);\n\taerodromes.events.unregister(\"click\", aerodromes, sendCustomAerodromeRequest);*/\n}\n\nfunction onSelectAerodromeMobile(feature) {\n\tsetLegend(feature);\n}\n\nfunction onSelectGramStation(feature) {\n\tsetLegend(feature);\n\tusucode = formatUndefined(feature.attributes.usucode).toLowerCase();\n\tmeteograms.events.register(\"click\", meteograms, sendStandardRequest);\n}\n\nfunction onUnSelectGramStation(feature) {\n\tresetLegend(feature);\n\tmeteograms.events.unregister(\"click\", meteograms, sendStandardRequest);\n}\n\nfunction onSelectGramStationMobile(feature) {\n\tsetLegend(feature);\n\tusucode = formatUndefined(feature.attributes.usucode).toLowerCase();\n\turl = \"meteogram.do?gram=\"+usucode+\"&type=meteograml\";\n\twindow.open(url, \"meteogram \"+usucode);\n}\n\n//to solve bug 1068\nfunction selectGramStation() {\n\tvar s = byId(\"gram_place\");\n\tvar usucode = s.options[s.selectedIndex].value;\n\tif (usucode!==\"\") {\n\t\turl = \"meteogram.do?gram=\"+usucode+\"&type=meteograml\";\n\t\twindow.open(url, \"meteogram \"+usucode);\t\t\n\t}\t\n}\n//\n\n/*function switchCustom() {\n\tif (isCustomOptionsActive==true) {\n\t\tisCustomOptionsActive=false;\t\t\n\t\tsetClassDivVis('custom','hidden');\n\t\tbyId('gram_com1').style.display=\"block\";\n\t\tbyId('gram_com2').style.display=\"none\";\n\t\tsetClassDivVis('dataLbl','hidden');\n\t\tsetClassDivVis('dataLayersDiv','hidden');\n\t\tmeteograms.setVisibility(true);\n\t\taerodromes.setVisibility(false);\n\t\tsetDefZoomAndCenter();\n\t\tbyId('testinfo').style.display=\"none\";\n\t} else {\n\t\tisCustomOptionsActive=true;\t\t\n\t\tsetClassDivVis('custom','visible');\n\t\tbyId('gram_com1').style.display=\"none\";\n\t\tbyId('gram_com2').style.display=\"block\";\n\t\tsetClassDivVis('dataLbl','visible');\n\t\tsetClassDivVis('dataLayersDiv','visible');\n\t\tmeteograms.setVisibility(false);\n\t\taerodromes.setVisibility(true);\n\t\tsetDefZoomAndCenter();\n\t\tbyId('testinfo').style.display=\"block\";\n\t}\n\tif (isCustomOptionsActive==true) {\n\t\tbyId('map_unavailable').style.display=\"none\";\n\t\tbyId('custom_unavailable').style.display=\"none\";\n\t\tisCustomOptionsActive=false;\n\t} else {\t\n\t\tbyId('map_unavailable').style.display=\"block\";\n\t\tbyId('custom_unavailable').style.display=\"block\";\n\t\tisCustomOptionsActive=true;\n\t}\n}\n\n// OTHER PART\n\nfunction expandProductDetails(product) {\n\tif (product.value==\"rb_sounding\") {\n\t\tbyId(\"soundingoptions\").style.display=\"block\";\n\t\tbyId(\"soundingchoiceinfo\").style.display=\"block\";\n\t\tbyId(\"gramoptions\").style.display=\"none\";\n\t} else if (product.value==\"rb_meteograms\") {\n\t\tbyId(\"soundingoptions\").style.display=\"none\";\n\t\tbyId(\"soundingchoiceinfo\").style.display=\"none\";\n\t\tbyId(\"gramoptions\").style.display=\"block\";\n\t} else {\n\t\tbyId(\"soundingoptions\").style.display=\"none\";\n\t\tbyId(\"soundingchoiceinfo\").style.display=\"none\";\n\t\tbyId(\"gramoptions\").style.display=\"none\";\n\t}\n}\n\nfunction displayPosFields(id) {\n\tif (id==\"byicao\") {\n\t\tbyId(\"gram_byicao\").style.display=\"block\";\n\t\tbyId(\"gram_bycoords\").style.display=\"none\";\n\t} else if (id==\"bycoords\") {\n\t\tbyId(\"gram_byicao\").style.display=\"none\";\n\t\tbyId(\"gram_bycoords\").style.display=\"block\";\n\t}\n}*/\n\nfunction setNumWxDefault() {\n\t/*byId('errormsg').style.display=\"none\";\n\tbyId('soundingoptions').style.display=\"none\";\n\tbyId(\"soundingchoiceinfo\").style.display=\"none\";\n\tbyId('gramoptions').style.display=\"none\";\n\tbyId('gram_com1').style.display=\"block\";\n\tbyId('gram_com2').style.display=\"none\";\n\tbyId('gram_bycoords').style.display=\"none\";\n\tsetClassDivVis('custom','hidden');\n\tsetSoundingTimeOptions();\n\tbyId('standcust').value = 'standard';*/\n}\n\nfunction sendStandardRequest(e) {\n\turl = \"meteogram.do?gram=\"+usucode+\"&type=meteograml\";\n\twindow.open(url, \"meteogram \"+usucode);\n}\n"
