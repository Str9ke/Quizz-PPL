            "text": ".lfr-portlet-item {\n  background: url(/website-theme/images/add_content/portlet_item.png) no-repeat 0 50%;\n  border: 1px solid #fff;\n  cursor: move;\n  font-size: 1.1em;\n  margin-bottom: 3px;\n  padding: 0 5px 0 20px; }\n\n.lfr-add-content .lfr-portlet-item.lfr-instanceable {\n  background-image: url(/website-theme/images/add_content/portlet_item_instanceable.png); }\n\n.lfr-add-content .lfr-portlet-item.lfr-archived-setup {\n  background-image: url(/website-theme/images/add_content/portlet_item_archived_setup.png);\n  margin-left: 20px; }\n\n.lfr-portlet-item:hover, .lfr-portlet-item.over {\n  background-color: #ffc;\n  border-color: #fc0; }\n\n.ie .lfr-portlet-item {\n  height: 1%; }\n\n.lfr-portlet-item p {\n  font-size: 1em;\n  margin: 0;\n  padding-right: 30px;\n  position: relative; }\n\n.lfr-portlet-item p a {\n  cursor: pointer;\n  font-size: 0.9em;\n  font-weight: bold;\n  position: absolute;\n  right: 0;\n  top: 0; }\n\n.ie .lfr-portlet-item p a {\n  top: -2px; }\n\n.ie6 .lfr-portlet-item p a {\n  right: 20px; }\n\n#layout_configuration_content {\n  width: 95%; }\n\n"
