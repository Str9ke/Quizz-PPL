            "text": "//disable ENTER key in forms\nfunction stopRKey(evt) {\n  var evt = (evt) ? evt : ((event) ? event : null);\n  var node = (evt.target) ? evt.target : ((evt.srcElement) ? evt.srcElement : null);\n  if ((evt.keyCode == 13) && (node.type==\"text\"))  {return false;}\n}\n\n//Print charts\nfunction framePrint(whichFrame){\n\t\n\tparent[whichFrame].focus();\n\tparent[whichFrame].print();\n}\n\n//Printing tool for result-pages\nfunction print_object(title, obj) {\n\t\t// define the print zone\n\t\tvar zi = document.getElementById(obj).innerHTML;\n\t\t\n\t\t// open a new window\n\t\tvar f = window.open(\"\", \"ZoneImpr\", \"height=500, width=600,toolbar=0, menubar=0, scrollbars=1, resizable=1,status=0, location=0, left=10, top=10\");\n\t\t\n\t\t// define the style\n\t\tf.document.body.style.color = '#000000';\n\t\tf.document.body.style.backgroundColor = '#FFFFFF';\n\t\tf.document.body.style.padding = \"10px\";\n\t\t\n\t\t// add information\n\t\tf.document.title = title;\n\t\tf.document.body.innerHTML = zi;\n\t\t\n\t\t// print and close window\n\t\tf.window.print();\n\t\tf.window.close();\n\t\treturn true;\n}\n\nfunction showMax(file, width, heigth) {\n\t\tnewWin=window.open(file,\"_blank\",\"top=150,left=200,width=920,height=550,menubar=0,scrollbars=yes\",true);\n}\n\n\n//define + open registration window\nfunction setWindowRegistration() {\n\t\twindow.open(\"\",\"_blank\",\"scrollbars,height=760,width=750,left=100,top=1\");\n\t}\n\n//get present time\nfunction get_present_time(){\n\t\t\tvar d=new Date();\n\t\t\tvar day=d.getUTCDate();\n\t\t\t\tif (day < 10){\n\t\t\t\tday = \"0\" + day;\n\t\t\t\t}\n\t\t\tvar month=d.getUTCMonth() + 1;\n\t\t\t\tif (month < 10){\n\t\t\t\tmonth = \"0\" + month;\n\t\t\t\t}\n\t\t\tvar year=d.getUTCFullYear();\n\t\t\tvar hour=d.getUTCHours();\n\t\t\t\tif (hour < 10){\n\t\t\t\thour = \"0\" + hour;\n\t\t\t\t}\n\t\t\tvar minutes=d.getUTCMinutes();\n\t\t\t\tif (minutes < 10){\n\t\t\t\tminutes = \"0\" + minutes;\n\t\t\t\t}\n\t\t\tvar seconds=d.getUTCSeconds();\n\t\t\t\tif (seconds < 10){\n\t\t\t\tseconds = \"0\" + seconds;\n\t\t\t\t}\n\t\t\t\n\t\t\tdocument.write(day + \".\" + month + \".\" + year + \" - \" + hour + \":\" + minutes + \":\" + seconds);\n\n}\n\n//set/get cookies startpage\n\nfunction setCookie(name, value, elementid) {\n\tvar date = new Date(2020,1,1,0,0,0,0);\n    var deCookie = name + \"=\" + escape(value) + \";expires=\" + date.toGMTString();\n    document.cookie = deCookie;\n    hidediv(elementid);\n}\n\nfunction getCookie(name) {\n  var dc = document.cookie;\n  var prefix = name + \"=\";\n  var begin = dc.indexOf(\"; \" + prefix);\n  if (begin == -1) {\n    begin = dc.indexOf(prefix);\n    if (begin != 0) return null;\n  }\n  else begin += 2;\n  var end = document.cookie.indexOf(\";\", begin);\n  if (end == -1)\n    end = dc.length;\n  return unescape(dc.substring(begin + prefix.length, end));\n}\n\n\n\n//\nfunction showdiv(elementid) { \nif (document.getElementById) { \n\t// DOM3 = IE5, NS6 \n\tdocument.getElementById(elementid).style.visibility = 'visible'; \n\t} \n\telse if (document.layers) { \n\t// Netscape 4 \n\tdocument.elementid.visibility = 'visible'; \n\t} \n\telse { \n\t// IE 4 \n\tdocument.all.elementid.style.visibility = 'visible'; \n\t} \n} \n\n\nfunction hidediv(elementid) { \n\nif (document.getElementById) { \n\t// DOM3 = IE5, NS6 \n\tdocument.getElementById(elementid).style.visibility = 'hidden'; \n\t} \n\telse if (document.layers) { \n \t// Netscape 4 \n\tdocument.elementid.visibility = 'hidden'; \n\t} \n\telse { \n\t// IE 4 \n\tdocument.all.elementid.style.visibility = 'hidden'; \n\t} \n} \n\n//show message on Startpage\nfunction showmessage(elementid) {\n\tif (getCookie('belgo_start') == null) {\n\t\tshowdiv(elementid);\n\t\t} else {\n\t\thidediv(elementid);\n\t\t}\n}\n\n\n// forces reload if login displayed in frame\n\nfunction reloadpg(){\n\t\tif (top.location.href != document.location.href){\n\t\t\ttop.location.href = document.location.href;\n\t\t}\n}\t\t\t\n\nfunction encodeFields(form, fieldIds) {\n\tif (typeof window.btoa !== \"function\") {\n\t\treturn true;\n\t}\n\ttry {\n\t\tfor (var i = 0; i < fieldIds.length; i++) {\n\t\t\tvar field = form.elements[fieldIds[i]];\n\t\t\tif (field && field.value) {\n\t\t\t\tfield.value = window.btoa(field.value);\n\t\t\t}\n\t\t}\n\t} catch (e) {\n\t\tif (window.console && typeof window.console.error === \"function\") {\n\t\t\tconsole.error(\"Failed to encode password fields\", e);\n\t\t}\n\t}\n\treturn true;\n}"
