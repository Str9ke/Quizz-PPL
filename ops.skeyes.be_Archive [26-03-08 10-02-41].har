            "size": 809,
            "text": "// Trims a String\nString.prototype.trim = function () {\n    return this.replace(/^\\s*/, \"\").replace(/\\s*$/, \"\");\n}\n\n// Updates the property value to reflect the state of the corresponding check box\nfunction handleCbOnClickEvent(control, property) {\n\tif (control.type == \"checkbox\" && property != null) {\n\t\tdocument.forms[0].elements[property].value=control.checked;   \n\t}   \n}\n\n// Updates the properties values to reflect the state of the corresponding radio buttons\nfunction handleRadioOnClickEvent(groupName, propPrefix) {\n\tradio_group = document.forms[0].elements[groupName];\n    for (var i = 0; i < radio_group.length; i++) {\n        var button = radio_group[i];\n        var property = button.value.substring(propPrefix.length);\n        document.forms[0].elements[property].value=button.checked;\n    }  \n}"
