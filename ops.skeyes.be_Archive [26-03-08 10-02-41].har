            "size": 2368,
            "text": "var isMobile = navigator.userAgent.match(/Android|BlackBerry|iPhone|iPad|iPod|Opera Mini|IEMobile/i);\n\nfunction byId(element) {\n\treturn document.getElementById(element);\n}\n\nfunction switchDisplay(element) {\n\tel = byId(element);\n\tif (el.style.display==\"none\") {\t\t\t\n\t\tel.style.display=\"block\";\n\t} else {\n\t\tel.style.display=\"none\";\n\t}\n}\n\nfunction switchVisibility(element) {\n\tel = byId(element);\n\tif (el.style.visibility==\"hidden\") {\n\t\tel.style.visibility=\"visible\";\n\t} else {\n\t\tel.style.visibility=\"hidden\";\n\t}\n}\n\nfunction setClassDivDisp(classname, value) {\n\t divs=document.getElementsByTagName(\"div\"); \n\t for (theDiv in divs) { \n\t\t if (divs[theDiv].className==classname) {\n\t\t\tdivs[theDiv].style.display=value;\n\t\t }\n\t } \t\n}\n\nfunction setClassDivVis(classname, value) {\n\t divs=document.getElementsByTagName(\"div\"); \n\t for (theDiv in divs) { \n\t\t if (divs[theDiv].className==classname) {\n\t\t\tdivs[theDiv].style.visibility=value;\n\t\t }\n\t } \t\n}\n\nfunction switchClassDivDisp(classname) { \n\t divs=document.getElementsByTagName(\"div\"); \n\t for (theDiv in divs) { \n\t\t if (divs[theDiv].className==classname) {\n\t\t\tif (divs[theDiv].style.display==\"visible\") {\n\t\t\t\tdivs[theDiv].style.display=\"none\";\n\t\t\t} else {\n\t\t\t\tdivs[theDiv].style.display=\"none\";\n\t\t\t} \n\t\t }\n\t } \n}\n\nfunction switchClassDivVis(classname) { \n\t divs=document.getElementsByTagName(\"div\"); \n\t for (theDiv in divs) { \n\t\t if (divs[theDiv].className==classname) {\n\t\t\tif (divs[theDiv].style.visibility==\"visible\") {\n\t\t\t\tdivs[theDiv].style.visibility=\"hidden\";\n\t\t\t} else {\n\t\t\t\tdivs[theDiv].style.visibility=\"visible\";\n\t\t\t} \n\t\t }\n\t } \n}\n\nfunction pad2(number) {   \n\tvar str = '' + number;\n\twhile (str.length < 2) {\n\t\tstr = '0' + str;\n\t}  \n\treturn str;\n}\n\nfunction formatDate(date) {\t\n\tvar dtstring = pad2(date.getDate())\n\t+ '-' + pad2(date.getMonth()+1)\t\t\n\t+ '-' + date.getFullYear()\n\t+ ' ' + pad2(date.getHours());\n\treturn dtstring;\n}\n\nfunction formatDateZ(date) {\t\n\tvar dtstringz = formatDate(date)+ ' Z';\n\treturn dtstringz;\n}\n\nfunction getMidnight(date) {\n\tdate.setDate(date.getUTCDate());\n\tdate.setHours(0);\n\tdate.setMinutes(0);\n\tdate.setSeconds(0);\n\tdate.setMilliseconds(0);\n\treturn date;\n}\n\nfunction formatUndefined(param){\n\tif (param==undefined) {\n\t\tparam=\" \";\n\t}\n\treturn param;\n}\n\nfunction isBrowserIE() {\n\tvar isIE = false;\n\tif (navigator.appName == 'Microsoft Internet Explorer') {\n\t\tisIE = true;\n\t}\n\treturn isIE;\n}"
