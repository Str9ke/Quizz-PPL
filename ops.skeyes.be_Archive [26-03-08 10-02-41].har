eoInfo{\n\tfont-size: 10px;\n}\n\nPRE.briefing{\n\tfont-size: 11px;\n}\n\n.iboxContainer{\n\tborder: 1px solid #80add6;\n\tpadding-left: 3px;\n}\n\n.iboxTitleWrapper{\n\tbackground-color: #CCCCCC;\n\tborder-bottom: 1px solid #80add6;\n}\n\n.iboxTitle{\t\n\tfont-weight: bold;\n\tcolor: #000000;\t\n\ttext-transform: uppercase;\n\tfont-size: 11px;\n}\n\n.iboxContent{\n\tbackground-color: #EFEFEF;\n\tfont-size: 10px;\n\tpadding-left: 3px;\n\tpadding-top: 3px;\n\tpadding-right: 3px;\n\tpadding-bottom: 3px;\n}\n\nlegend{\n\tfont-weight:bold;\n\tcolor: #B07660;\n}\n\nfieldset{\n\tmargin-bottom: 15px;\n}\n\n.fieldsettabkes{\n\twidth: 500;\n\tbackground-color: #DCE8F4;\n\ttext-align: left;\n}\n\n\nTH{\n\tfont-weight: bold;\n\tbackground-color: #EFEFEF;\n\tborder-bottom: 1px solid orange;\n\tfont-style: italic;\n}\n\n.attention\n{\n    FONT-SIZE: 10px;\n    COLOR: #ff0000;\n    FONT-FAMILY: verdana\n}\n\n.NotamDisclaimer\n{\n    FONT-SIZE: 10px;\n    COLOR: #ff0000;\n    FONT-FAMILY: verdana;\n    FONT-WEIGHT: bold;\n}\n\n/* the login is to big */\n.login {\n    font-family: verdana,helvetica;\n\tfont-size: 8px;\n\twidth: 90%;\n}  \n\n/* styles servicemeteo*/\n.dropDownMeteo {\n\tfont-family: verdana,helvetica;\n\tfont-size: 10px;\n\t}\n\n.iframe {\n    background-color: #FFFFFF;\n    font-family: verdana,helvetica;\n\tfont-size: 10px;\n\tborder: 0px;\n\twidth: 99%;\n\theight:97%;\n\t}\n.tab {\n\tfont-family: verdana,helvetica;\n\tfont-size: 9px; font-weight: bold;\n\tposition:absolute; text-align: center; \n\tborder: 2px; border-color:#009ee0;\n\tborder-style: solid;\n\tborder-bottom-style: none; \n\theight:37px;\n\twidth:160px;\n\tcolor:#009ee0;\n\tmargin:0px;\n\ttop:0px;\n\tbackground-color:#D0D3D4\n}\n.panel {\n\tbackground-color: #ffffff;\n    font-family: verdana,helvetica;\n\tfont-size: 10px;\n}\n\n.popup {\n\tbackground-color: #DCE8F4;\n}\n\t\t\n\n/*end styles servicemeteo*/\n\n/* style for the glossary page*/\n.glossary\n{\n    font-family: verdana,helvetica;\n\tfont-size: 16px;\n}\n.date\n{\n    FONT-SIZE: 10px;\n    FONT-STYLE: italic\n}\n.leftmenu\n{\n    FONT-SIZE: 10px;\n    COLOR: #009ee0;\n    FONT-FAMILY: verdana;\n    FONT-WEIGHT: bold;\n    color: #009ee0;\n    LINE-HEIGHT: 50%;\n}\n.greyleftmenu\n{\n    FONT-SIZE: 10px;\n    COLOR: gray;\n    FONT-FAMILY: verdana;\n    FONT-WEIGHT: bold;\n    color: #009ee0;\n    LINE-HEIGHT: 50%;\n}\n.leftmenu_r\n{\n    FONT-SIZE: 10px;\n    COLOR: #009ee0;\n    FONT-FAMILY: verdana;\n    color: #009ee0;\n    TEXT-INDENT: 15px;\n    LINE-HEIGHT: 50%;\n}\n.greyleftmenu_r\n{\n    FONT-SIZE: 10px;\n    COLOR: gray;\n    FONT-FAMILY: verdana;\n    color: #009ee0;\n    TEXT-INDENT: 15px;\n    LINE-HEIGHT: 50%;\n}\n.title\n{\n    FONT-SIZE: 10px;\n    TEXT-TRANSFORM: uppercase;\n    COLOR: #009ee0;\n    FONT-STYLE: normal;\n    FONT-FAMILY: verdana;\n    LETTER-SPACING: 0px\n}\n.content\n{\n\tpadding-right: 15px;\n    FONT-SIZE: 10px;\n    COLOR: black;\n    FONT-FAMILY: verdana;\n    text-align: justify;\n    LETTER-SPACING: normal;\n}\n.pibcontent\n{\n\tBORDER-STYLE: solid double;\n\tBORDER-COLOR: #b07660;\n    FONT-SIZE: 10px;\n    COLOR: black;\n    FONT-FAMILY: verdana;\n    LETTER-SPACING: normal\n}\n.notamlabel\n{\n    color: black;\n    FONT-FAMILY: verdana;\n    FONT-SIZE: 10px;\n    TEXT-ALIGN: left;\n    background-color: yellow;\n}\n.facts\n{\n    FONT-SIZE: 9px;\n    COLOR: black;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: right\n}\n.website\n{\n    FONT-SIZE: 10px;\n    COLOR: #fdf5e6;\n    FONT-FAMILY: verdana, 'Helvetica CondensedBlack';\n    LETTER-SPACING: 1px;\n    TEXT-DECORATION: none\n}\n.level1\n{\n    FONT-SIZE: 12px;\n    COLOR: slategray;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: left;\n    TEXT-DECORATION: none\n}\n.level2\n{\n    COLOR: dimgray;    \n    FONT-SIZE: 11px;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: left;\n    TEXT-DECORATION: none\n}\n.orgtitle\n{\n    FONT-SIZE: 10px;\n    FONT-FAMILY: verdana;\n    BACKGROUND-COLOR: #c7cfd4;\n    TEXT-ALIGN: center\n}\n.orgfunction\n{\n    FONT-SIZE: 10px;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: left\n}\n.orgname\n{\n    FONT-SIZE: 9px;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: left\n}\n\n.link\n{\n    FONT-SIZE: 11px;\n    COLOR: #009ee0;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: left;\n    TEXT-DECORATION: none\n}\n\n.greyedoutlink\n{\n    FONT-SIZE: 10px;\n    COLOR: gray;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: left;\n    TEXT-DECORATION: none\n}\n\n.linkhome\n{\n    FONT-SIZE: 8px;\n    COLOR: #009ee0;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: left;\n    TEXT-DECORATION: none\n}\n.level3\n{\n    FONT-SIZE: 10px;\n    COLOR: black;\n    FONT-FAMILY: verdana;\n    TEXT-DECORATION: none\n}\n.mail\n{\n    FONT-SIZE: 9px;\n    COLOR: #009ee0;\n    TEXT-DECORATION: none\t\n}\n.orangecontent\n{\n    FONT-SIZE: 12px;\n    COLOR: #d05c00;\n    FONT-FAMILY: verdana\n}\n.row1left\n{\n    FONT-SIZE: 10px;\n    COLOR: black;\n    FONT-FAMILY: verdana;\n    BACKGROUND-COLOR: #99cccc;\n    TEXT-ALIGN: left\n}\n.row2left\n{\n    FONT-SIZE: 10px;\n    COLOR: black;\n    FONT-FAMILY: verdana;\n    BACKGROUND-COLOR: #e2f0f7;\n    TEXT-ALIGN: left\n}\n.row2right\n{\n    FONT-SIZE: 10px;\n    COLOR: black;\n    FONT-FAMILY: verdana;\n    BACKGROUND-COLOR: #e2f0f7;\n    TEXT-ALIGN: right\n}\n.row1right\n{\n    FONT-SIZE: 10px;\n    COLOR: black;\n    FONT-FAMILY: verdana;\n    BACKGROUND-COLOR: #99cccc;\n    TEXT-ALIGN: right\n}\n.orange\n{\n    FONT-SIZE: 14px;\n    COLOR: #c88544;\n    FONT-FAMILY: verdana;\n    TEXT-DECORATION: none\n}\n.brun\n{\n    FONT-SIZE: 14px;\n    COLOR: #b07660;\n    FONT-FAMILY: verdana;\n    TEXT-DECORATION: none\n}\n.gris\n{\n    FONT-SIZE: 11px;\n    COLOR: dimgray;\n    FONT-FAMILY: verdana;\n    TEXT-DECORATION: none\n}\n\n.disclaim\n{\n    FONT-SIZE: x-small;\n    COLOR: #cc0000;\n    FONT-STYLE: italic;\n    FONT-FAMILY: verdana, Helvetica, Verdana\n}\n.briefing\n{\n    FONT-SIZE: small;\n    FONT-FAMILY: \"Courier New\", Courier, Fixed\n}\n.center\n{\n    FONT-SIZE: 9px;\n    COLOR: black;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: center\n}\n.sstitle\n{\n    FONT-SIZE: 10px;\n    FONT-WEIGHT: bold;\n    COLOR: #009ee0;\n    FONT-FAMILY: verdana; \n}\n.ssstitle\n{\n    FONT-SIZE: 10px;\n    COLOR: #009ee0;\n    FONT-FAMILY: verdana\n}\n.thumbnail\n{\n    FONT-SIZE: 9px;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: center;\n    TEXT-DECORATION: none\n}\n/* tags are on alphabetical order */\nA\n{\n    COLOR: #009EE0;\n    FONT-FAMILY: Verdana;\n    TEXT-DECORATION: none;\n}\n\na:visited {color: #009EE0; text-decoration: none}\na:hover {color: #df0303; text-decoration: none}\na:active {color: #df0303; text-decoration: none}\n\nBODY\n{\n    FONT-SIZE: 10px;\n    COLOR: black;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: justify;\t\n    BACKGROUND-COLOR: #ffffff;\n    margin: 0px;\n}\nTEXTAREA\n{\n    FONT-SIZE: 10px;\n\tFONT-FAMILY: verdana;    \n\t\n}\n\nH1, H2, H3, H4{\n\tFONT-FAMILY: verdana, Helvetica;\n    COLOR: #009ee0;\n    FONT-SIZE: 14px;\n    FONT-FAMILY: verdana;\n}\n\nH2{\n    FONT-SIZE: 13px;\n}\n\nH3{\n    FONT-SIZE: 12px;\n    margin-bottom: 3px;\n}\n\nH4{\n    FONT-SIZE: 11px;\n    margin-bottom: 3px;\n}\nHR\n{\n\tCOLOR: #009ee0\n}\nINPUT\n{\n    FONT-SIZE: 10px;\n    FONT-FAMILY: verdana\n}\nLI\n{\n    TEXT-INDENT: 0px\n}\nOL\n{\n    LIST-STYLE-POSITION: inside;\n    TEXT-INDENT: 0px\n}\nOPTION\n{\n    FONT-SIZE: 10px;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: left\n}\nTABLE\n{\n    FONT-SIZE: 10px;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: left\n}\nTD\n{\n    FONT-SIZE: 10px;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: left\n}\nUL\n{\n    LIST-STYLE-POSITION: inside;\n    TEXT-INDENT: 0px\n}\n\n.ralignedtd\n{\n    FONT-SIZE: 10px;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: right\n}\n\n.logoHolder{\n\tpadding-top: 10px;\n\tpadding-left: 10px;\n}\n\n.loginFormLabel{\n\tfont-family: verdana,helvetica;\n\tfont-size: 8px;\n}\n\n.smallInput, .errorMsg{\n\tfont-size: 8px;\n}\n\n.errorMsg{\n\tcolor: red;\n}\n\n.orange-mini\n{\n    FONT-SIZE: 11px;\n    COLOR: #c88544;\n    FONT-FAMILY: verdana;\n    TEXT-DECORATION: none\n}\n\n.sssstitle-bold\n{\n    FONT-SIZE: 8px;\n    FONT-WEIGHT: bold;\n    COLOR: #009ee0;\n    FONT-FAMILY: verdana\n}\n\n.ssstitle-bold\n{\n    FONT-SIZE: 10px;\n    FONT-WEIGHT: bold;\n    COLOR: #009ee0;\n    FONT-FAMILY: verdana\n}\n.compulsoryasterisk\n{\n    FONT-SIZE: 10px;\n    FONT-WEIGHT: bold;\n    COLOR: #c88544;\n    FONT-FAMILY: verdana\n}\n\n/* GLOSSARY */\n\n#letter {\nfont:bold 14px verdana;\nwidth:100%;\nbackground-color:#EFEFEF;\nborder-bottom: solid 1px orange;\n}\n\n#top {\nfloat:right;\nposition:relative;\ntop:-25px;\nright:30px;\nfont:10px verdana;\n}\n\ndt {\nfont:bold 12px verdana;\n\n\n}\n\n#def ul {\nlist-style:circle outside;\n\nmargin-top:5px;\nmargin-bottom:5px;\n\n}\n\n#def li {\nfont:10px verdana;\nmargin-left:15px;\n}\n\ndd {\nfont: 10px verdana;\nmargin-bottom:10px;\n\n}\n\n.productInfo {\n\ttext-align: center;\t\n\tfont-style: italic; \n\tfont-size: 10px;\n\tcolor: grey;\n\tpadding: 1px 10px 10px 1px !important;\n\tfont-family: verdana, arial;\n}\n\n.divError {\n\tposition:absolute;\n\ttop:93px;\n\tleft:350px;\n\tz-index:0;\n\tbackground-color:#DCE8F4;\n}\n\n#aismeteo {\n\tmargin: 0 20px;\n\tmax-width: 687px;\n}\n\n#aismeteo .operational {\n\ttext-align: center;\n}\n\n#aismeteo .Opera_box{\n\tpadding:5px;\n}\n\n#aismeteo a.info {\n   color: black;\n   position: relative;\n   text-decoration: none;\n}\n\n#aismeteo a.info span {\n   display: none;\n}\n\n#aismeteo a.info:hover {\n   background: none; /* IE bug correction */\n   z-index: 500;\n}\n\n#aismeteo a.info:hover span {\n   display: inline;\n   position: absolute;\n   white-space: nowrap;\n   top: 0px;\n   left: 0px;\n   width:160px;\n   height:auto;\n   text-align: center;\n   background: lightgrey;\n   color: #0E718A;\n   padding: 5px;\n   border-radius: 20px;\n\t\t-moz-border-radius:20px 20px 20px 20px;\n\t\t-webkit-border-radius:20px 20px 20px 20px;\n\twhite-space:pre-wrap;\n}\n\n.popup ul {\n\tlist-style-position: inside; \n\tmargin: 0px;\n\tpadding: 0px; \n\tlist-style-image: url(\"../resources/images/services/bullet_mid.gif\");\t\n}\n\n/* numwxmodel_detailinfo.jsp */\n .howintersound_list li {\n \tpadding-bottom: 1em;\n }\n \n .howintersound_list table {\n    margin-top: 1em;\n    margin-left: 3em;\n }\n \n  .howintersound_list td {\n\tline-height: 1em;\n/*     padding-left: 3em; */\n }\n \n .infoframe {\n\tborder: 1px solid #84CBB3;\n\tmargin-left: auto;\n\tmargin-right: auto;\n\tpadding: 5px 40px 5px 5px;\n\tposition: relative;\n\tmax-width: 500px;\n }\n \n@media all and (max-width: 381px) {\n\t\n\t#aismeteo img {\n\t\theight: 100px;\n\t}\n\t\n}\n\n"
