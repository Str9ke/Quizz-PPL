          "content": {
            "mimeType": "application/javascript",
            "size": 8848,
            "text": "/*\n * other version of the meteo_2.js required for flight briefing charts section\n */\n\n\nfunction checkuncheckopmet(){\n\tif (document.getElementById('met').checked){\n\t\tdocument.getElementById('metar').checked = true;\n\t\tdocument.getElementById('taf').checked = true;\n\t\tdocument.getElementById('sigmet').checked = true;\n\t\tdocument.getElementById('gamet').checked = true;\n\t}\n\telse{\n\t\tdocument.getElementById('metar').checked = false;\n\t\tdocument.getElementById('taf').checked = false;\n\t\tdocument.getElementById('sigmet').checked = false;\n\t\tdocument.getElementById('gamet').checked = false;\n\t}\n}\n\nfunction showavailablelevels(frm){\n\tvar area = document.forms[frm].chartarea2.value;\n\tvar chartfldiv = document.forms[frm].chartfldiv;\n\tavfl = \"\";\n\n\tswitch(area){\n\t\tcase \"Africa\":\n\t\t\tavfl = \"<select name='chartfl' class='dropDownMeteo'>\";\n\t\t\tavfl = avfl + \"<option value='FL050'>FL050</option>\";\n\t\t\tavfl = avfl + \"<option value='FL080'>FL080</option>\";\n\t\t\tavfl = avfl + \"<option value='FL100'>FL100</option>\";\n\t\t\tavfl = avfl + \"<option value='FL140'>FL140</option>\";\n\t\t\tavfl = avfl + \"<option value='FL180'>FL180</option>\";\n\t\t\tavfl = avfl + \"<option value='FL210'>FL210</option>\";\n\t\t\tavfl = avfl + \"<option value='FL240'>FL240</option>\";\n\t\t\tavfl = avfl + \"<option value='FL270'>FL270</option>\";\n\t\t\tavfl = avfl + \"<option value='FL300'>FL300</option>\";\n\t\t\tavfl = avfl + \"<option value='FL320'>FL320</option>\";\n\t\t\tavfl = avfl + \"<option value='FL340'>FL340</option>\";\n\t\t\tavfl = avfl + \"<option value='FL360'>FL360</option>\";\n\t\t\tavfl = avfl + \"<option value='FL390'>FL390</option>\";\n\t\t\tavfl = avfl + \"<option value='FL410'>FL410</option>\";\n\t\t\tavfl = avfl + \"<option value='FL450'>FL450</option>\";\n\t\t\tavfl = avfl + \"<option value='FL480'>FL480</option>\";\n\t\t\tavfl = avfl + \"<option value='FL530'>FL530</option>\";\n\t\t\tavlf = avf