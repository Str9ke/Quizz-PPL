            "text": "\n\n\n\n\n<link rel=\"stylesheet\" href=\"/opersite/resources/strutslayoutconfig/default.css\" type=\"text/css\">\n<script>var imgsrc=\"/opersite/resources/strutslayoutconfig/\"; var scriptsrc=\"/opersite/resources/strutslayoutconfig/\"; var langue=\"en\"; var contextPath=\"/opersite\";</script><script src=\"/opersite/resources/strutslayoutconfig/javascript.js\"></script> \n  \n\n\t\n<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\">\n\n\n\n\n\n\n<html>\t\n\t\n\n\n<head>\n\t\n\t\n\t\n\t\t<base href=\"https://ops.skeyes.be/opersite/\">\n\t\n\t\n\t<meta http-equiv=\"Content-Type\" content=\"text/html; charset=ISO-8859-1\">\n\t<link href=\"Styles/master.css\" rel=\"stylesheet\" type=\"text/css\">\n\t<!--[if IE]>\n      \t<link href=\"Styles/masterIE.css\" rel=\"stylesheet\" type=\"text/css\">\n   \t<![endif]-->\n\t<link rel=\"stylesheet\" href=\"/dojo/dijit/themes/tundra/tundra.css\"/>\n\t<link rel=\"stylesheet\" href=\"/dojo/dojox/widget/Toaster/Toaster.css\"/>\n\t<title>skeyes website</title>\n\t\t<script language=\"Javascript\" src=\"resources/javascript/tools.js\"></script>\t\t\n</head>\n\n<BODY>\n\n\t\t<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"687\">\n\t\t\t<tr> \n\t\t\t<td valign=\"top\" style=\"text-align:right;\" width=\"95%\">\n\t\t\t\t\t\t\t\t\n\n\n\n\n<script type=\"text/javascript\">\n\tfunction doSwitch(lang, country, page){\n\t\tdocument.switchLanguageDynaForm.language.value=lang;\n\t\tdocument.switchLanguageDynaForm.country.value=country;\t\n\t\tdocument.switchLanguageDynaForm.submit();\n\t}\n\t\n\n</script>\n<table cellspacing=\"0\" cellpadding=\"3\" border=\"0\"  width=\"100%\">\n\t<tr>\t\t\n\n<!-- \t<td valign=\"middle\" width=\"25\"><a href=\"intro.do\"><img src=\"resources/images/home.png\" border=\"0\"></a></td>\n\t\t<td valign=\"middle\" width=\"25\"><a href=\"mailto:info@belgocontrol.be\"><img src=\"resources/images/mail.png\" border=\"0\"></a></td>\n\t\t<td valign=\"middle\" width=\"25\"><a href=\"sitemap.do?mChange=8\"><img src=\"resources/images/sitemap.png\" border=\"0\"></a></td>\n -->\t\t\n \t\t<td nowrap=\"nowrap\" style=\"padding-left: 20px; text-align: right;\">\n\t\t\t\n\t\t\t\n\t\t\t\t<a href=\"logout.do\" class=\"toolbarMenu\">Log out</a>\n\t\t\t\t&nbsp;&nbsp;\n\t\t\t\t\n\t\t\t\t\t<a href=\"profileforward.do\" class=\"toolbarMenu\">My Account</a>\n\t\t\t\t\n\t\t\t\t\t\t\n\t\t</td>\n\t</tr>\n</table>\n\t\t\t</td>\n\t\t\t<td width=\"100\">&nbsp;</td>\n\t\t\t</tr>\n\t\t\t\n\t\t\t<tr>\t\t\t\t\n\t\t\t\t<td valign=\"top\" class=\"bodyTile\" colspan=\"2\">\n\t\n<!-- <span class=\"pageTitle\">Meteo Operational Information</span> -->\n\t\t\n \t\t<table> \n\t\t\t<tr>\n\t\t\t\t<td class=\"tabsmain\">\n\t\t\t\t\t<table border=\"0\" cellspacing=\"0\" cellpadding=\"0\"><tr><td><table width=\"100%\" cellspacing=\"0\" cellpadding=\"0\"><tr><td id=\"tabs0head0\" class=\"ongletTextEna\" width=\"120\" onmouseover=\"onTabHeaderOver(0,0,'ongletTextEna')\" onclick=\"selectTab(0,5,0,'ongletTextEna','ongletTextDis','ongletTextErr',null,null);\">OPMET Data</td><td width=\"5\" class=\"ongletSpace\">&nbsp;</td><td id=\"tabs0head1\" class=\"ongletTextDis\" width=\"120\" onmouseover=\"onTabHeaderOver(0,1,'ongletTextEna')\" onclick=\"selectTab(0,5,1,'ongletTextEna','ongletTextDis','ongletTextErr',null,null);\">Forecast Bulletins</td><td width=\"5\" class=\"ongletSpace\">&nbsp;</td><td id=\"tabs0head2\" class=\"ongletTextDis\" width=\"140\" onmouseover=\"onTabHeaderOver(0,2,'ongletTextEna')\" onclick=\"selectTab(0,5,2,'ongletTextEna','ongletTextDis','ongletTextErr',null,null);\">Flight Briefing Charts</td><td width=\"5\" class=\"ongletSpace\">&nbsp;</td><td id=\"tabs0head3\" class=\"ongletTextDis\" width=\"120\" onmouseover=\"onTabHeaderOver(0,3,'ongletTextEna')\" onclick=\"selectTab(0,5,3,'ongletTextEna','ongletTextDis','ongletTextErr',null,null);\">Remote Sensing</td><td width=\"5\" class=\"ongletSpace\">&nbsp;</td><td id=\"tabs0head4\" class=\"ongletTextDis\" width=\"160\" onmouseover=\"onTabHeaderOver(0,4,'ongletTextEna')\" onclick=\"selectTab(0,5,4,'ongletTextEna','ongletTextDis','ongletTextErr',null,null);\">Num Wx-model Output</td><td width=\"5\" class=\"ongletSpace\">&nbsp;</td><td class=\"ongletSpace\">&nbsp;</td></tr><tr><td height=\"5\" colspan=\"11\" class=\"ongletMiddle\">&nbsp;</td></tr></table></td></tr><tr><td class=\"ongletMain\">\n\t\t\t\t\t\t<div id=\"tabs0tab0\"><table border=\"0\" cellspacing=\"0\" cellpadding=\"0\" class=\"clsAction\">\n\t\t\t\t\t\t\t<tr><td class=\"tabdim\">\n\t\t\t\t\t\t\t\t\n\n\n\n\n\n\t\n<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\">\n\n\n\n\t\n\t\t<table> \n\t\t\t<tr>\n\t\t\t\t<td class=\"framecell\">\n\t\t\t\t\t<iframe width=\"692\" height=\"545\" src=\"/opersite/opmet.do?cmd=init\" name=\"opmetFrame\" frameborder=\"0\" scrolling=\"auto\">\n\t\t\t\t\t</iframe>\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t</table>\n\t \n\n\n\n\n\t\t\t\t\t\t\t</td></tr>\n\t\t\t\t\t\t</table></div>\n\t\t\t\t\t\t<div id=\"tabs0tab1\" style=\"display:none;\"><table border=\"0\" cellspacing=\"0\" cellpadding=\"0\" class=\"clsAction\">\n\t\t\t\t\t\t\t<tr><td class=\"tabdim\">\n\t\t\t\t\t\t\t\t\n\n\n\n\n\n<script language=javascript>\n\nfunction viewChart(formName, type){\n\tdocument.forms[formName].action = \"forecast.do?cmd=retrieveCharts\"\n\tdocument.forms[formName].chartType.value = type;\n\tdocument.forms[formName].submit();\n}\n\n</script>\n\n\t\n<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\">\n\n\n\n\n<html>\t\n\t\n\n\n<head>\n\t\n\t\n\t\n\t\t<base href=\"https://ops.skeyes.be/opersite/\">\n\t\n\t\n\t<meta http-equiv=\"Content-Type\" content=\"text/html; charset=ISO-8859-1\">\n\t<link href=\"Styles/master.css\" rel=\"stylesheet\" type=\"text/css\">\n\t<!--[if IE]>\n      \t<link href=\"Styles/masterIE.css\" rel=\"stylesheet\" type=\"text/css\">\n   \t<![endif]-->\n\t<link rel=\"stylesheet\" href=\"/dojo/dijit/themes/tundra/tundra.css\"/>\n\t<link rel=\"stylesheet\" href=\"/dojo/dojox/widget/Toaster/Toaster.css\"/>\n\t<title>skeyes website</title>\n\t\t<script language=\"Javascript\" src=\"resources/javascript/tools.js\"></script>\t\t\n</head>\n\n\t\t<DIV class=\"innerFrameDiv\">\n\t\t\t\t \n\n<script language=\"javascript\">\n\n\tif (navigator.appName == \"Microsoft Internet Explorer\" && navigator.appVersion >= \"4.0\")\n\t\t{document.write(\"<table width='710'>\")};\n\tif (navigator.appName != \"Microsoft Internet Explorer\")\n\t\t{document.write(\"<table width='692'>\")};\n\t\t\t\t\n</script>\n\n<div style=\"display:none\">\n\n</div>\n\n<form name=\"forecastDynaForm\" method=\"post\" action=\"/opersite/forecast.do?cmd=retrieveCharts\" target=\"_blank\">\n\t<input type=\"hidden\" name=\"chartType\" value=\"\">\n\t\t<span style=\"color:#b07660; background-color: #dce8f4; position:relative; top:5px; margin-left:10px; padding: 5px; left:0px; align: left;\" >Select Bulletin Type</span>\n\t<center>\t\n\t\t<table style=\"width: 700px; padding: 20px; padding-left:10px; border: solid 1px #b07660;\">\n\t\t\t<tr><td>&nbsp;</td></tr>\n\t\t\t<tr >\n\t\t\t\t<td style=\"padding: 5px; padding-left:35px;\" width=\"150\" >General Forecast</td>\n\t\t\t\t<td valign=\"middle\" width=\"50\"><INPUT TYPE=\"BUTTON\" value=\"View\" onclick=\"viewChart('forecastDynaForm', 'genfor');\" ></td>\n\t\t\t\t<td style=\"padding: 5px;\" >&nbsp;No General Warning active</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td height=\"10\"></td>\n\t\t\t\t<td>&nbsp;</td>\n\t\t\t\t<td>&nbsp;</td>\t\t\t\t\n\t\t\t</tr>\t\t\n\t\t\t<tr>\n\t\t\t\t\n\t\t\t\t<td style=\"padding: 5px; padding-left:35px;\" width=\"150\"; >Ballooning Bulletin</td>\n\t\t\t\t<td valign=\"middle\" colspan=\"2\"><input type=\"button\"  value=\"View\" onclick=\"viewChart('forecastDynaForm', 'balloon');\"></td>\n\t\t\t\t<td>&nbsp;</td>\n\t\t\t</tr>\t\t\n\t\t\t<tr>\n\t\t\t\t<td height=\"10\"></td>\n\t\t\t\t<td>&nbsp;</td>\n\t\t\t\t<td>&nbsp;</td>\t\t\t\t\t\t\t\t\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td style=\"padding: 5px; padding-left:35px;\" width=\"150\" >Medium Range Forecast</td>\n\t\t\t\t<td valign=\"middle\"><input type=\"button\" value=\"View\" onclick=\"viewChart('forecastDynaForm', 'mediumrange');\" ></td>\n\t\t\t\t<td>&nbsp;</td>\t\t\t\t\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td height=\"10\"></td>\n\t\t\t\t<td>&nbsp;</td>\n\t\t\t\t<td>&nbsp;</td>\t\t\t\t\t\t\t\t\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td style=\"padding: 5px; padding-left:35px;\" width=\"150\" >EBCI Local Forecast</td>\n\t\t\t\t<td valign=\"middle\"><input type=\"button\" value=\"View\" onclick=\"viewChart('forecastDynaForm', 'mmfEBCI');\" ></td>\n\t\t\t\t<td>&nbsp;</td>\t\t\t\t\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td height=\"10\"></td>\n\t\t\t\t<td>&nbsp;</td>\n\t\t\t\t<td>&nbsp;</td>\t\t\t\t\t\t\t\t\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td style=\"padding: 5px; padding-left:35px;\" width=\"150\">EBAW Local Forecast\n\t\t\t\t</td>\n\t\t\t\t<td valign=\"middle\"><input type=\"button\" value=\"View\"\n\t\t\t\t\t\tonclick=\"viewChart('forecastDynaForm', 'mmfEBAW');\"></td>\n\t\t\t\t<td>&nbsp;</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td height=\"10\"></td>\n\t\t\t\t<td>&nbsp;</td>\n\t\t\t\t<td>&nbsp;</td>\t\t\t\t\t\t\t\t\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td style=\"padding: 5px; padding-left:35px;\" width=\"150\">EBLG Local Forecast\n\t\t\t\t</td>\n\t\t\t\t<td valign=\"middle\"><input type=\"button\" value=\"View\"\n\t\t\t\t\t\tonclick=\"viewChart('forecastDynaForm', 'mmfEBLG');\"></td>\n\t\t\t\t<td>&nbsp;</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td height=\"10\"></td>\n\t\t\t\t<td>&nbsp;</td>\n\t\t\t\t<td>&nbsp;</td>\t\t\t\t\t\t\t\t\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td style=\"padding: 5px; padding-left:35px;\" width=\"150\">EBOS Local Forecast\n\t\t\t\t</td>\n\t\t\t\t<td valign=\"middle\"><input type=\"button\" value=\"View\"\n\t\t\t\t\t\tonclick=\"viewChart('forecastDynaForm', 'mmfEBOS');\"></td>\n\t\t\t\t<td>&nbsp;</td>\n\t\t\t</tr>\t\t\t\n\t\t\t<tr><td>&nbsp;</td></tr>\t\t\t\n\t\t</table>\n\t</center>\n</form>\n\n\t