            "text": "var olPath = OpenLayers._getScriptLocation();\nOpenLayers.ImgPath = olPath+'/theme/belgocontrol/img/'\n\t\nvar map;\nvar proj_4326 = new OpenLayers.Projection(\"EPSG:4326\");\nvar proj_900913 = new OpenLayers.Projection('EPSG:900913');\n\nvar wwwserver = \"https://ops.skeyes.be\";\nvar geoserver = \"https://ops.skeyes.be/geoserver/\";\nvar workspace_common = \"tempogis\";\nvar workspace_meteo = \"tempogis\";\nvar geowebcache = \"gwc/service/wms\";\nvar nsUriPrefix = \"http://www.belgocontrol.be/geoserver/\"\n\nvar osm;\nvar countries;\nvar aerodromes;\nvar selectedLayer;\n\nvar aerodrome_icao = \"\";\nvar aerodrome_name = \"\";\nvar aerodrome_coords = \"\";\nvar aerodrome_met = \"\";\n\nvar centerLonLatDef;\nvar zoomDef;\n\nvar aerodromes_style \n\t\nfunction init_commons() {\t\n\n\t// code for display bug with IE 11\n\tvar isIE11=(!(window.ActiveXObject) && \"ActiveXObject\" in window);\n\tif(isIE11) {\n\t\tvar _class = OpenLayers.Format.XML;\n\t\tvar originalWriteFunction = _class.prototype.write;\n\t\tvar patchedWriteFunction = function()\n\t\t{\n\t\t\tvar child = originalWriteFunction.apply( this, arguments );\t\t\n\t\t\tchild = child.replace(new RegExp('xmlns:NS\\\\d+=\"\" NS\\\\d+:', 'g'), ''); \t\n\t\t\treturn child;\n\t\t}\n\t\t_class.prototype.write = patchedWriteFunction;\n\t}\n\t//\n\t\n\tcenterLonLatDef = new OpenLayers.LonLat(473107.84,6568397.78);\n\tzoomDef = 3;\n\tosmZoomOffset = 4;\n\tresolutionsTab = [156543.03390625,\n\t                  78271.516953125,\n\t                  39135.7584765625,\n\t                  19567.87923828125,\n\t                  9783.939619140625,\n\t                  4891.9698095703125,\n\t                  2445.9849047851562,\n\t                  1222.9924523925781,\n\t                  611.4962261962891,\n\t                  305.74811309814453,\n\t                  152.87405654907226,\n\t                  76.43702827453613,\n\t                  38.218514137268066,\n\t                  19.109257068634033,\n\t                  9.554628534317017,\n\t                  4.777314267158508,\n\t                  2.388657133579254,\n\t                  1.194328566789627,\n\t                  0.5971642833948135];\n\tresolutions = resolutionsTab.slice(4,9);\n\t\n\tmap = new OpenLayers.Map(\n\t\t'map',\n\t\t{\n\t\t\ttheme: olPath+'/theme/belgocontrol/style.css',\n\t\t\tcontrols: [],\n\t\t\tdisplayProjection: proj_4326, //usefull to show position in degrees\n\t\t\tnumZoomLevels: resolutions.length, //necessary to avoid bug with panZoom\n\t\t\tprojection: proj_900913,\t\t\n\t\t\tresolutions: resolutions,\n\t\t\trestrictedExtent: bounds,\n\t\t\tunits: 'm'\n\t\t}\n\t);\n\t\t\n\t// styles\n\tif (isMobile) {\n\t\taerodromes_style = new OpenLayers.Style({\n\t\t\t'pointRadius' : \"${radius}\",\n\t\t\t'fillColor' : '#1793d7',\n\t\t\t'graphicName' : 'triangle',\n\t\t\t'stroke' : false,\n\t\t\t'label' : '${icao}',\n\t\t\t'fontColor' : '#234f96',\n\t\t\t'labelSelect' : true\n\t\t},{\n\t\t\tcontext : {\n\t\t\t\tradius: function() {\n\t\t\t\t\tvar radius_factor = 7-(Math.round(Math.floor(arguments[0].layer.map.getResolution()/600)));\n\t\t\t\t\tif (radius_factor < 1) { \n\t\t\t\t\t\tradius_factor = 1;\n\t\t\t\t\t} \n\t\t\t\t\taerodromes_style.defaultStyle.fontSize = 2*radius_factor;\n\t\t\t\t\taerodromes_style.defaultStyle.labelYOffset = -2*radius_factor;\n\t\t\t\t\treturn radius_factor;\n\t\t\t\t}\n\t\t\t}\n\t\t});\t\t\n\t} else {\n\t\taerodromes_style = new OpenLayers.Style({\n\t\t\t'pointRadius' : \"${radius}\",\n\t\t\t'fillColor' : '#1793d7',\n\t\t\t'graphicName' : 'triangle',\n\t\t\t'stroke' : false\n\t\t},{\n\t\t\tcontext : {\n\t\t\t\tradius: function() {\n\t\t\t\t\tvar radius_factor = 7-(Math.round(Math.floor(arguments[0].layer.map.getResolution()/600)));\n\t\t\t\t\tif (radius_factor < 1) { \n\t\t\t\t\t\tradius_factor = 1;\n\t\t\t\t\t} \n\t\t\t\t\treturn radius_factor;\n\t\t\t\t}\n\t\t\t}\n\t\t});\t\t\n\t}\t\n\t\t\n\tvar aerodromes_style_selected = new OpenLayers.Style({\n\t\t'pointRadius': 10,\n\t\t'graphicZIndex': 50\n\t});\t\t\t\n\t\n\tvar aerodromes_style_map = new OpenLayers.StyleMap({\n\t\t'default': aerodromes_style,\n\t\t'select': aerodromes_style_selected\n\t});\n\t\n\t// layers\n    osm = new OpenLayers.Layer.OSM(\"OpenStreetMap\", wwwserver+\"/html/belgocontrol_static/geodata/osm-mapnik/${z}/${x}/${y}.png\", {\n    \t\tzoomOffset: osmZoomOffset, \n    \t\tresolutions: resolutions,\n    \t\tattribution: \"<p>Map data <a target='_blank' href='http://www.openstreetmap.org/'>Open Street Map</a> and contributors, <a target='_blank' href='http://opendatacommons.org/licenses/odbl/'>ODbL</a></p>\"\n\t});\n\t\n    countries = new OpenLayers.Layer.WMS(\n\t\t'countries',\n\t\tgeoserver+geowebcache,\n\t\t{\n\t\t\tlayers: workspace_common+':european_countries',\n\t\t\tbgcolor: '0x17427f'\n\t\t},\n\t\t{\n\t\t\tisBaseLayer: true,\n\t\t\tattribution: \"<p style='text-align:center'>Map data : skeyes</p>\"\n\t\t}\n\t);\t\n\t\n\taerodromes = new OpenLayers.Layer.Vector(\"aerodromes\", {\n\t\tstrategies: [new OpenLayers.Strategy.BBOX()],\n\t\tprotocol: new OpenLayers.Protocol.WFS({\n\t\t\tversion: \"1.1.0\",\n\t\t\tsrsName: \"EPSG:900913\",\n\t\t\turl:  geoserver+\"wfs\",\n\t\t\tfeatureType: aerodromeFeatureType,\n\t\t\tfeaturePrefix: workspace_common,\n\t\t\tgeometryName: 'geom'\n\t\t}),\n\t\t\tstyleMap: aerodromes_style_map,\n\t\t\trendererOptions: { zIndexing: true }\n\t});\n\t\n\tmap.addLayers([countries, osm, aerodromes]);\n\t\n\t// controls\n\tvar nav_ctrl = new OpenLayers.Control.Navigation();\n\t\t\t\n\tvar panZoom_ctrl = new OpenLayers.Control.BelgoPanZoom();\n\tpanZoom_ctrl.setCenterZoomDef(centerLonLatDef,zoomDef);\n\t\t\t\n\tvar scale_ctrl = new OpenLayers.Control.ScaleLine({geodesic: true});\n\n\tvar mousePos_ctrl = new OpenLayers.Control.MousePosition({\n\t\tdiv: byId(\"mouse_position\"),\n\t\tnumDigits: 2,\n\t\tprefix: \"LONG : \",\n\t\tseparator: \"<br />LAT : \"\n\t});\n\t\n\tlaySwitch_ctrl = new OpenLayers.Control.LayerSwitcher({\n\t\tdiv: byId('layers_switch_control'),\n\t\troundedCorner: false\n\t});\n\t\n\tvar attribution_ctrl = new OpenLayers.Control.Attribution();\n\t\t\n\tvar controls_array = [\n\t    nav_ctrl,\n\t    panZoom_ctrl,\n\t\tscale_ctrl,\t\t\t\n\t\tmousePos_ctrl,\n\t\tlaySwitch_ctrl,\n\t\tattribution_ctrl\n\t];\n\t\n\tmap.addControls(controls_array);\n\t\n\t// aerodromes control : not for smartphone and tablet\n\tif (!isMobile) {\n\t\tvar aerodromes_ctrl = new OpenLayers.Control.SelectFeature (\n\t\t\taerodromes,\n\t\t\t{\n\t\t\t\thover: true,\n\t\t\t\tonSelect: onSelectAerodrome,\n\t\t\t\tonUnselect: onUnselectAerodrome\n\t\t\t}\n\t\t);\n\t} else {\n\t\tvar aerodromes_ctrl = new OpenLayers.Control.SelectFeature (\n\t\t\t\taerodromes,\n\t\t\t\t{\n\t\t\t\t\tonSelect: onSelectAerodromeMobile\n\t\t\t\t}\n\t\t\t);\t\t\n\t}\n\tmap.addControl(aerodromes_ctrl);\n\taerodromes_ctrl.activate();\n\t\n\tmap.setCenter(centerLonLatDef,zoomDef);\n}\n\nfunction setLegend(feature) {\n\tbyId('mouse_position').style.display=\"none\";\t\n\taerodrome_name = feature.attributes.name;\n\taerodrome_icao = formatUndefined(feature.attributes.icao);\n\taerodrome_met = formatUndefined(feature.attributes.sa)+\" \"+formatUndefined(feature.attributes.fc)+\" \"+formatUndefined(feature.attributes.ft);\n\tvar lonlat = new OpenLayers.LonLat(feature.geometry.x,feature.geometry.y).transform(proj_900913,proj_4326);\n\tvar lat = lonlat.lat.toFixed(2);\n\tvar lon = lonlat.lon.toFixed(2);\n\taerodrome_coords = \"LONG : \"+lon+\"<br />LAT : \"+lat;\n\tvar content = \"<span>\"+aerodrome_icao+\"</span><br /><span class='minitxt'>\"+aerodrome_name+\"</span><br /><span class='minitxt'>\"+aerodrome_met+\"</span><br /><span>\"+aerodrome_coords+\"</span>\";\n\tbyId('feature_prop').innerHTML=content;\t\n}\n\nfunction resetLegend(feature) {\n\taerodrome_name = \"\";\n\taerodrome_icao = \"\";\n\tbyId('feature_prop').innerHTML='';\n\tbyId('mouse_position').style.display=\"block\";\n}\n"
