            "text": "\n\n\n\n<script type=\"text/javascript\" src=\"/opersite/resources/javascript/tools.js\"> </script>\n<script type=\"text/javascript\" src=\"/opersite/resources/openlayers/OpenLayers.js\"> </script>\n<script type=\"text/javascript\" src=\"/opersite/resources/openlayers/belgo_extra_ol_js/BelgoPanZoom.js\"> </script>\n<script type=\"text/javascript\" src=\"/opersite/resources/javascript/general.js\"></script>\n<script type=\"text/javascript\" src=\"/opersite/resources/javascript/meteo/general.js\"> </script>\n<script type=\"text/javascript\" src=\"/opersite/resources/javascript/meteo/ol_map_commons.js\"> </script>\n<script type=\"text/javascript\" src=\"/opersite/resources/javascript/meteo/numwx.js\"> </script>\n<layout:skin includeScript=\"true\"/> \n  \n<html>\n<head>\n\t<link href=\"Styles/master.css\" rel=\"stylesheet\" type=\"text/css\">\n\t<link href=\"Styles/meteo/ol_map_commons.css\" rel=\"stylesheet\" type=\"text/css\">\n\t<link href=\"Styles/meteo/numwx.css\" rel=\"stylesheet\" type=\"text/css\">\n</head>\n<body class=\"iframeBody\" onload=\"init();setNumWxDefault()\">\n\n\t<div class=\"info\" onclick=\"showMax('numWxModelInfo.do', 50, 500);\">\n\t\t<a>Help</a>\n\t</div>\n\t\n\t<div id=\"errormsg\"></div>\n\n\t<table width=\"100%\">\n\t\t<tr>\n\t\t\t<td valign=\"top\">\n\t\t\t\t<table>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t<fieldset>\n\t\t\t\t\t\t\t\t<legend>Select Wind / Precipitation Charts</legend>\n\t\t\t\t\t\t\t\t<table>\n\t\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t\t<td style=\"padding:3px\"><a href=\"remoteSensingDetail.do?html=wind10&type=numwx\" target=\"_blank\"><img src=\"resources/images/services/meteo/numwx/10m.png\" border=\"0\" alt=\"10m wind chart\"></a></td>\n\t\t\t\t\t\t\t\t\t\t<td style=\"padding:3px\"><a href=\"remoteSensingDetail.do?html=windfl10&type=numwx\" target=\"_blank\"><img src=\"resources/images/services/meteo/numwx/fl010.png\" border=\"0\" alt=\"FL10 wind chart\"></a></td>\n\t\t\t\t\t\t\t\t\t\t<td style=\"padding:3px\"><a href=\"remoteSensingDetail.do?html=windfl20&type=numwx\" target=\"_blank\"><img src=\"resources/images/services/meteo/numwx/fl020.png\" border=\"0\" alt=\"FL20 wind chart\"></a></td>\n\t\t\t\t\t\t\t\t\t\t<td style=\"padding:3px\"><a href=\"remoteSensingDetail.do?html=windfl30&type=numwx\" target=\"_blank\"><img src=\"resources/images/services/meteo/numwx/fl030.png\" border=\"0\" alt=\"FL30 wind chart\"></a></td>\n\t\t\t\t\t\t\t\t\t\t<td style=\"padding:3px\"><a href=\"remoteSensingDetail.do?html=windfl50&type=numwx\" target=\"_blank\"><img src=\"resources/images/services/meteo/numwx/fl050.png\" border=\"0\" alt=\"FL50 wind chart\"></a></td>\n\t\t\t\t\t\t\t\t\t\t<td style=\"padding:3px\"><a href=\"remoteSensingDetail.do?html=windfl100&type=numwx\" target=\"_blank\"><img src=\"resources/images/services/meteo/numwx/fl100.png\" border=\"0\" alt=\"FL100 wind chart\"></a></td>\n\t\t\t\t\t\t\t\t\t\t<td width=\"50px\">&nbsp;</td>\n\t\t\t\t\t\t\t\t\t\t<td style=\"padding:3px\"><a href=\"remoteSensingDetail.do?html=numprec&type=numwx\" target=\"_blank\"><img src=\"resources/images/services/meteo/numwx/precipitation.png\" border=\"0\" alt=\"precipitation chart\"></a></td>\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t</table>\n\t\t\t\t\t\t\t</fieldset>\t\t\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</table>\n\t\t\t</td>\n\t\t</tr>\n\t</table>\n\t\n<form>\n\t<fieldset>\n\t<legend>Select Localized Products (Soundings, Meteograms, Vertical Cross-sections)</legend>\n\t\t<p><em>Select a location or click a point on the map</em></p>\n\t\t<select id=\"gram_place\" onchange=\"selectGramStation()\">\n\t\t\t<option value=\"\" ></option>\n\t\t\t<option value=\"ebaw\">ANTWERPEN</option>\n\t\t\t<option value=\"ebbe\">BEAUVECHAIN</option>\n\t\t\t<option value=\"ebbr\">BRUSSELS</option>\n\t\t\t<option value=\"ebci\">CHARLEROI</option>\n\t\t\t<option value=\"ebcv\">CHIEVRES</option>\n\t\t\t<option value=\"ebfs\">FLORENNES</option>\t\t\t\n\t\t\t<option value=\"ebbl\">KLEINE-BROGEL</option>\n\t\t\t<option value=\"ebkt\">KORTRIJK</option>\n\t\t\t<option value=\"eblg\">LIEGE</option>\n\t\t\t<option value=\"ebos\">OOSTENDE</option>\t\t\t\n\t\t\t<option value=\"ebsh\">SAINT-HUBERT</option>\n\t\t\t<option value=\"snik\">SINT NIKLAAS</option>\n\t\t\t<option value=\"ebsp\">SPA</option>\n\t\t\t<option value=\"tiel\">TIELT</option>\t\t\t\n\t\t</select>\n\t\t<br /><br />\n\t\t<div id='map' style='width: 560px; height: 280px'></div>\n\t\t<div id=\"layers_switch_control\"></div>\n\t\t<div id='stations_info'>\n\t\t\t<div id=\"locator\">\n\t\t\t\t<span id=\"feature_prop\"></span>\n\t\t\t\t<br/>\n\t\t\t\t<span id=\"mouse_position\"></span>\t\t\t\t\t\n\t\t\t</div>\n\t\t</div>\n\t</fieldset>\n</form>\n\t\n\t<form id=\"sender\"></form>\n\t\n\t</body>\n</html>"
