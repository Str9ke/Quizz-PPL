            "text": ".lfr-form-row {\n  border-bottom: 1px solid #CCC;\n  margin-bottom: 10px;\n  margin-top: 10px;\n  padding: 5px;\n  padding-top: 1px;\n  position: relative; }\n\n.ie .lfr-form-row {\n  width: 100%; }\n\n.lfr-form-row:after {\n  clear: both;\n  content: \"\";\n  display: block;\n  height: 0; }\n\n.lfr-form-row:hover {\n  background-color: #DFFCCB;\n  border: solid #B2FF3A;\n  border-width: 1px 0;\n  padding-top: 0; }\n\n.lfr-form-row .aui-field {\n  clear: none;\n  float: left; }\n\n.lfr-form-row-inline .aui-field {\n  margin-right: 5px; }\n\n.lfr-form-row legend .field-label {\n  float: left;\n  margin-right: 10px; }\n\n.lfr-form-row .handle-sort-vertical {\n  background: url(/website-theme/images/application/handle_sort_vertical.png) no-repeat 0 50%;\n  cursor: move;\n  padding-left: 20px; }\n\n.lfr-form-row fieldset {\n  border: none;\n  margin: 0;\n  padding: 0; }\n\n.lfr-autorow-controls.aui-toolbar {\n  padding: 1px; }\n\n.lfr-autorow-controls {\n  bottom: 5px;\n  position: absolute;\n  right: 5px; }\n\n.ie6 .lfr-form-row, .ie7 .lfr-form-row {\n  zoom: 1; }\n\n/* ---------- RTL ---------- */\n.rtl .lfr-autorow-controls {\n  bottom: 0;\n  float: left;\n  left: 5px;\n  position: relative;\n  right: 0;\n  text-align: left; }\n.rtl .row-names {\n  float: right; }\n\n"
