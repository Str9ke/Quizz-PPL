            "size": 13582,
            "text": "\n\n\n\n\n\n<html>\n\n\n\n<head>\n\t\n\t\n\t\n\t\t<base href=\"https://ops.skeyes.be/opersite/\">\n\t\n\t\n\t<meta http-equiv=\"Content-Type\" content=\"text/html; charset=ISO-8859-1\">\n\t<link href=\"Styles/master.css\" rel=\"stylesheet\" type=\"text/css\">\n\t<!--[if IE]>\n      \t<link href=\"Styles/masterIE.css\" rel=\"stylesheet\" type=\"text/css\">\n   \t<![endif]-->\n\t<link rel=\"stylesheet\" href=\"/dojo/dijit/themes/tundra/tundra.css\"/>\n\t<link rel=\"stylesheet\" href=\"/dojo/dojox/widget/Toaster/Toaster.css\"/>\n\t<title>skeyes website</title>\n\t\t<script language=\"Javascript\" src=\"resources/javascript/tools.js\"></script>\t\t\n</head>\n\n<head>\n<link href=\"Styles/master.css\" rel=\"stylesheet\"\n\ttype=\"text/css\">\n<style type=\"text/css\">\n\t#icaolist {\n\t\twidth: 508px;\n\t}\n\t#icaomapicon {\n\t\tmargin-left: 10px;\n\t}\n</style>\n</head>\n<script type=\"text/javascript\"\n\tsrc=\"/opersite/resources/javascript/general.js\"></script>\n<script type=\"text/javascript\">\n\nvar jsMetarHistoryOptions = new Array();\n\n\n\tjsMetarHistoryOptions[0]='no';\n\n\tjsMetarHistoryOptions[3]='last 3 hours';\n\n\tjsMetarHistoryOptions[6]='last 6 hours';\n\n\tjsMetarHistoryOptions[12]='last 12 hours';\n\n\tjsMetarHistoryOptions[24]='last 24 hours';\n\n\n\tvar jsTemplateNames = new Array();\t\n\t var jsIcao_content = new Array();\n\t\t var jsCountry1 = new Array();\n\t\t var jsCountry2 = new Array();\n\t\t var jsCountry3 = new Array();\n\t\t var jsCountry4 = new Array();\n\t\t var jsCountry5 = new Array();\n\t\t var jsCountry6 = new Array();\n\t\t      var jstaf = new Array();\n\t\t    var jsmetar = new Array();\n\t\t   var jssigmet = new Array();\n\t    var jsgamairmet = new Array();\n\t    var jsMetarHistoryValue = new Array();\n\t    var jsMetarHistoryLabel = new Array();\n\n\t\n\t\npopUpsBlocked = true;\n\nvar mapwin;\nfunction starthelp(formName) {\n\tif (mapwin==undefined || mapwin.closed) {\n\t\t//Detect IE7+\n\t\tversion=0\n\t\tif (navigator.appVersion.indexOf(\"MSIE\")!=-1){\n\t\ttemp=navigator.appVersion.split(\"MSIE\");\n\t\tversion=parseFloat(temp[1]);\n\t\t}\n\t\tif ((navigator.userAgent.indexOf(\"Mozilla/5\")!=-1) || version >= 7){//=================Netscape6.0======================\n\t\t\tmapwin = window.open(\"\", \"mapicao\", \"height=540,width=860\");\n\t\t    document.forms[formName].action = \"mapIcao.do?cmd=init&amp\";\n\t\t    document.forms[formName].target = \"mapicao\";\n\t\t    document.forms[formName].submit(); \n\t    } else {\n\t    detectPopupBlocker();\n\t    if (popUpsBlocked == false){\n\t    \tmapwin = window.open(\"\", \"mapicao\", \"height=700,width=950\");\n\t\t    document.forms[formName].action = \"mapIcao.do?cmd=init&amp\";\n\t\t    document.forms[formName].target = \"mapicao\";\n\t\t    document.forms[formName].submit(); \n\t\t    }\t    \n\t    }\t\t\n\t} else {\n\t\talert(\"The help map is already open\");\n\t}\n}\n\nfunction detectPopupBlocker() {\n  var myTest = window.open(\"about:blank\",\"\",\"directories=no,height=1,width=1,menubar=no,resizable=no,scrollbars=no,status=no,titlebar=no,top=0,location=no\");\n  if (!myTest) {\n  \talert('Not all functionality on this page is available.\\nPlease disable your popup blocking software and refresh this page.');\n    popUpsBlocked = true;\n  } else {\n     myTest.close();\n    popUpsBlocked = false;\n  }\n     myTest.close();\n  \n}\n\nfunction askForTplName(formName){\n\tvar tplName = new String(\"\");\n\twhile (tplName == \"\") {\n\t\ttplName = prompt(\"Please enter a name for this selection\");\n\t\ttplName = tplName.trim();\n\t\tif (tplName.length > 20) {\n\t\t\talert(\"The template name cannot exceed \" + 20 + \" characters.\");\n\t\t\ttplName = \"\"; continue;\n\t\t}\n\t\tfor (var i=0; i < document.forms[formName].template.options.length; i++){\n\t\t\tif (tplName == document.forms[formName].template.options[i].value){\n\t\t\t\talert(\"A template with that name already exists. Choose another template name.\");\n\t\t\t\ttplName = \"\"; break;\n\t\t\t}\n\t\t}\n\t}\n\treturn tplName;\n}\n\nfunction saveTpl(formName){\n\ttplAction(formName, \"opmet.do?cmd=saveTemplate\", askForTplName(formName), \"save\");\n}\n\nfunction resetFrm(formName){\n\tdocument.forms[formName].action = \"opmet.do?cmd=reset\";\n\tdocument.forms[formName].submit();\n\tdocument.forms[formName].reset();\n}\n\n\nfunction allcountryFrm(formName, selection){\n\tif (selection == 'selectcount'){\n\t\tdocument.forms[formName].action = \"opmet.do?cmd=selectall&selection=counttrue\";\n\t} else if (selection == 'deselectcount'){\n\t\tdocument.forms[formName].action = \"opmet.do?cmd=selectall&selection=countfalse\";\n\t} else if (selection == 'selectopmet'){\n\t\tdocument.forms[formName].action = \"opmet.do?cmd=selectall&selection=opmettrue\";\n\t} else if (selection == 'deselectopmet'){\n\t\tdocument.forms[formName].action = \"opmet.do?cmd=selectall&selection=opmetfalse\";\n\t}\n\tdocument.forms[formName].submit();\n\t\n}\n\nfunction updateTpl(formName){ \n\ttplActionDefault(formName, \"opmet.do?cmd=updateTemplate\", \"update\");\n}\n\nfunction deleteTpl(formName){ \n\tif (confirm('Really delete this Template ?'))\n\ttplActionDefault(formName, \"opmet.do?cmd=deleteTemplate\", \"delete\");\n}\n\nfunction renameTpl(formName){ \n\tdocument.forms[formName].newTemplateName.value = askForTplName(formName); \n\t//avoid having empty values as name\n\tif((document.forms[formName].newTemplateName.value != \"\") && (document.forms[formName].newTemplateName.value != \"null\")){\n\ttplActionDefault(formName, \"opmet.do?cmd=renameTemplate\", \"rename\");\n\t}\n}\n\nfunction tplAction(formName, uri, tplName, action){\n \t\t\t//avoid double values when saving\n \t\t\t\n// modify by GOG on 13/12/2006\n// implement action to avoid double name when saving (save or rename)\n// bugs Acceptance Test phase 02 testscript 25 point 3\n\t\t\tif (action == \"save\"){\n\t\t  \t//iterate through options\n\t\t\tfor(i=document.opmetForm.template.options.length-1;i>=1;i--)\n\t\t\t{\n\t\t\t\tif (document.opmetForm.template.options[i].value == tplName){\n\n\t\t\t\talert('Template already exist - Please select new name or update');\n\t\t\t\t\treturn false;\n\t\t\t\t} \n\t\t\t}\n\t\t\t\t\n\t\t\t}\n\t\t\t\t\tif (tplName != null){\n\t\t\t\t\tdocument.forms[formName].action = uri;\n\t\t\t\t\tdocument.forms[formName].templateName.value = tplName;\n\t\t\t\t\tdocument.forms[formName].target=\"opmetFrame\";\n\t\t\t\t\tdocument.forms[formName].submit();\n\t\t\t\t\t} else {\n\t\t\t\t\t\t//the user clicked cancel\n\t\t\t\t\t}\t\t\t\n\n\n}\n\nfunction tplActionDefault(formName, uri, action){\n\tvar selectedTpl = document.forms[formName].template.value;\n\ttplAction(formName, uri, selectedTpl, action);\n}\n\nfunction chgformcontent(){\n\tvar isIE=0, isNav4=0, isStandard=0;\n\tvar range = \"\";\n\tif (document.all){ // for IE\n\t\trange = document.all.opmetForm;\n\t} else {\n\t\tif (document.layers){ // for Netscape 4.7\n\t\t\trange = document.content.document.opmetForm;\n\t\t} else {\n\t\t\tif (document.getElementById) {// for Netscape 6/7\n\t\t\t\trange = document.opmetForm;\n\t\t\t}\n\t\t}\n\t}\n\n\tvar templselected=range.template.selectedIndex-1;\n\t\trange.land1.checked = false;\n\t\trange.land2.checked = false;\n\t\trange.land3.checked = false;\n\t\trange.land4.checked = false;\n\t\trange.land5.checked = false;\n\t\trange.land6.checked = false;\n\t\trange.taf.checked = false;\n\t\trange.metar.checked = false;\n\t\trange.sigmet.checked = false;\n\t\trange.gametairmet.checked = false;\n\t\t\n\t\n\tif (templselected==-1) {} else\n\t{\n\n//\t\tdocument.opmetForm.getElementByName(\"icaocodes\").value=jsIcao_content[templselected];\n// \t\tchange code because incompatibility with firefox\n\t\tdocument.opmetForm.icaocodes.value=jsIcao_content[templselected];\n\t\tdocument.opmetForm.metarHistory.label=jsMetarHistoryLabel[templselected];\n\t\tdocument.opmetForm.metarHistory.value=jsMetarHistoryValue[templselected];\n\t\t\n// modify by GOG on 12/12/2006\n// bugs (see acceptance testscript25 from vta point 2), impossible to select Belgium +Lux for the update template)\n//\t\tdocument.opmetForm.land1.value=jsCountry1[templselected];\n// end modify\n\t\tif (jsCountry1[templselected]==\"true\")\n\t\t\trange.land1.checked=true;\n\t\tif (jsCountry2[templselected]==\"true\")\n\t\t\trange.land2.checked=true;\n\t\tif (jsCountry3[templselected]==\"true\")\n\t\t\trange.land3.checked=true;\n\t\tif (jsCountry4[templselected]==\"true\")\n\t\t\trange.land4.checked=true;\n\t\tif (jsCountry5[templselected]==\"true\")\n\t\t\trange.land5.checked=true;\n\t\tif (jsCountry6[templselected]==\"true\")\n\t\t\trange.land6.checked=true;\n\t\tif (jstaf[templselected]==\"true\")\n\t\t\trange.taf.checked=true;\n\t\tif (jsmetar[templselected]==\"true\")\n\t\t\trange.metar.checked=true;\n\t\tif (jssigmet[templselected]==\"true\")\n\t\t\trange.sigmet.checked=true;\n\t\tif (jsgamairmet[templselected]==\"true\")\n\t\t\trange.gametairmet.checked=true;\n\t}\n}\nfunction uppercase(formName){\n\tdocument.forms[formName].icaocodes.value = document.forms[formName].icaocodes.value.toUpperCase();\n\t\n}\n\n</script>\n\n<body class=\"iframeBody\">\n\n<div id=\"wait\" style=\"position: absolute; left:30%; top:20%; background-color: transparent; z-index:5; visibility:hidden; \">\n\t<table bgcolor=\"white\" border=\"2\" bordercolor=\"#e5edf4\" width=\"250\" >\n\t<tr>\n\t\t<td style=\"text-align: center\">\n\t\t<br/>\n\t\t\t<h1>Please Wait</h1>\n\t\t\tRetrieving your data...\n\t\t<br/>\n\t<img border=\"0\"\n\tsrc=\"resources/images/wait_animated.gif\"\n\twidth=\"32\" height=\"32\">\t\n\t\t</td>\n\t</tr>\n\t</table>\n</div>\n\n\n\n<table width=\"640\">\n\t\n\t\n\n\t\t<tr>\n\t\t\t<td>\n\t\t\t<p class=\"attention\"><br>\n\t\t\tIf no data is found for a given location and type of message this\n\t\t\tdoes not necessarily imply that no such message has been generated,\n\t\t\tbut only that no valid message has been received or stored by our EUR\n\t\t\tOPMET Database. The user assumes the entire risk related to his use\n\t\t\tof data.</p>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td><form name=\"opmetForm\" method=\"post\" action=\"/opersite/opmetData.do?cmd=retrieveOpmet\" target=\"_self\">\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t<input type=\"hidden\" name=\"templateName\" value=\"\">\n\t\t\t\t<input type=\"hidden\" name=\"newTemplateName\" value=\"\">\n\t\t\t\t<input type=\"hidden\" name=\"selectCountry\" value=\"\">\n\t\t\t\t<table style=\"background-color: #EFEFEF; border: 1px solid #CCCCCC;\">\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td width=\"80\">&nbsp;<B>Templates</B></td>\n\t\t\t\t\t\t<td width=\"200\" valign=\"top\"\n\t\t\t\t\t\t\tstyle=\"padding-left: 10; padding-right: 10;\"><select name=\"template\" size=\"1\" onchange=\"chgformcontent()\" class=\"dropDownMeteo\"><option value=\"select\">select template</option></select></td>\n\t\t\t\t\t\t<td align=\"right\" width=\"100%\"><input name=\"saveTemplate\"\n\t\t\t\t\t\t\ttype=\"button\" value=\"Save As\" onClick=\"saveTpl('opmetForm');\">\n\t\t\t\t\t\t&nbsp;<input name=\"updTemplate\" type=\"button\" value=\"Update\"\n\t\t\t\t\t\t\tonClick=\"updateTpl('opmetForm');\"> &nbsp;<input\n\t\t\t\t\t\t\tname=\"delTemplate\" type=\"button\" value=\"Delete\"\n\t\t\t\t\t\t\tonClick=\"deleteTpl('opmetForm');\"> &nbsp;<input\n\t\t\t\t\t\t\tname=\"renTemplate\" type=\"button\" value=\"Rename\"\n\t\t\t\t\t\t\tonClick=\"renameTpl('opmetForm');\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t</table>\n\t\t\t\t<br>\n\t\t\t\t<fieldset style=\"width: 640;\"><legend><b>Select\n\t\t\t\tICAO-codes</b></legend>\n\t\t\t\t<ul>\n\t\t\t\t\t<li>ICAO code\n\t\t\t\t\t\t<table border=\"0\">\n\t\t\t\t\t\t\t<tbody>\n\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<td><input type=\"text\" name=\"icaocodes\" maxlength=\"600\" size=\"70\" value=\"\" onchange=\"uppercase('opmetForm');\" id=\"icaolist\">\n\t\t\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t\t\t\t<td><a href=\"javascript:starthelp('opmetForm');\" id=\"icaomapicon\"><img src=\"resources/images/services/meteo/opmet/map_selection_icon.png\" border=\"0\" title=\"selection with map\" alt=\"selection with map\"></a></td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t<td>\t\t\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t<font color=\"red\">*</font>\n\t\t\t\t\t\t\t\t\t<em>You can look for several ICAO codes, but they must be separated by &quot;;&quot;</em>\n\t\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t</tbody>\n\t\t\t\t\t\t\t</table>\n\t\t\t\t\t\t</li>\n\t\t\t\t\t</ul>\n\t\t\t\t\t<ul>\n\t\t\t\t\t\t<li>Country\n\t\t\t\t\t\t\t<table border=\"0\">\n\t\t\t\t\t\t\t\t<tbody>\n\t\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t\t<td width=\"10\"><input type=\"checkbox\" name=\"land1\" value=\"on\"></td>\n\t\t\t\t\t\t\t\t\t\t<td align=\"left\" width=\"168\">Belgium &amp; Luxembourg</td>\n\t\t\t\t\t\t\t\t\t\t<td width=\"10\"><input type=\"checkbox\" name=\"land2\" value=\"on\"></td>\n\t\t\t\t\t\t\t\t\t\t<td width=\"113\">The Netherlands</td>\n\t\t\t\t\t\t\t\t\t\t<td width=\"10\"><input type=\"checkbox\" name=\"land3\" value=\"on\"></td>\n\t\t\t\t\t\t\t\t\t\t<td width=\"115\">France</td>\n\t\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t\t<td width=\"10\"><input type=\"checkbox\" name=\"land4\" value=\"on\"></td>\n\t\t\t\t\t\t\t\t\t\t<td align=\"left\" width=\"168\">Germany</td>\n\t\t\t\t\t\t\t\t\t\t<td width=\"10\"><input type=\"checkbox\" name=\"land5\" value=\"on\"></td>\n\t\t\t\t\t\t\t\t\t\t<td width=\"113\">England</td>\n\t\t\t\t\t\t\t\t\t\t<td width=\"10\"><input type=\"checkbox\" name=\"land6\" value=\"on\"></td>\n\t\t\t\t\t\t\t\t\t\t<td width=\"115\">Switzerland</td>\n\t\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t</tbody>\n\t\t\t\t\t\t\t</table>\n\t\t\t\t\t\t</li>\n\t\t\t\t\t</ul>\n\t\t\t\t</fieldset>\n\t\t\t\t<fieldset style=\"width: 640;\"><legend><b>Select the OPMET data type</b></legend>\n\t\t\t\t\t<table>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<td style=\"text-align: right;\">METAR</td>\n\t\t\t\t\t\t\t<td><input type=\"checkbox\" name=\"metar\" value=\"on\"></td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<td style=\"text-align: right;\">TAF</td>\n\t\t\t\t\t\t\t<td><input type=\"checkbox\" name=\"taf\" value=\"on\"></td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<td style=\"text-align: right;\">SIGMET</td>\n\t\t\t\t\t\t\t<td><input type=\"checkbox\" name=\"sigmet\" value=\"on\"></td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<td style=\"text-align: right;\">GAMET / AIRMET</td>\n\t\t\t\t\t\t\t<td><input type=\"checkbox\" name=\"gametairmet\" value=\"on\"></td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<td style=\"text-align: right;\">METAR HISTORY </td>\n\t\t\t\t\t\t\t<td><select name=\"metarHistory\" style=\"margin-left:4px\" class=\"dropDownMeteo\"><option value=\"0\" selected=\"selected\">no</option>\r\n<option value=\"3\">last 3 hours</option>\r\n<option value=\"6\">last 6 hours</option>\r\n<option value=\"12\">last 12 hours</option>\r\n<option value=\"24\">last 24 hours</option></select></td>\n\t\t\t\t\t\t</tr>\n\t\n\t\t\t\t\t</table>\n\t\t\t\t</fieldset>\n\t\t\t\t<table width=\"600\">\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td width=\"100\" valign=\"top\" rowspan=\"2\"><input type=\"submit\" value=\"Retrieve OPMET\" onclick=\"showdiv('wait');\"></td>\n\t\t\t\t\t\t<td valign=\"top\"><input name=\"resetForm\" type=\"reset\"\n\t\t\t\t\t\t\tvalue=\"Reset\" onClick=\"resetFrm('opmetForm');\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td>&nbsp;</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</table>\n\t\t\t</form></td>\n\t\t</tr>\n\t\n</table>\n</body>\n</html>\n"
