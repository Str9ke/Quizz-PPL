            "mimeType": "application/javascript",
            "size": 2668,
            "text": "// animation.js\n\nvar\n  count = 1;\n  current_image = 1; \n  playing = false;\n  speed = 500;\n  imsg = new Array();\n  timerID=null;\nvar isNS = 0;//IE\nif (navigator.appName.substring(0,7)==\"Netscape\" & navigator.appVersion.substring(0,3) <=\"4.7\") {//netscape & version<4.7\nisNS = 1;\n}\n\nfunction load_check() {\ncount++\n\n}\n \n\nfunction play_images(){\n\nplaying = true; \ncurrent_image = 0;\nwindow.clearTimeout(timerID);\ntimerID = window.setTimeout(\"animate_image()\", speed, \"JavaScript\");\n}\n\nfunction animate_image() {\n\nif (current_image==count-1){current_image=1;}else{current_image=current_image+1};\nif (isNS == 1)\nwindow.document.content.document.map.src = imsg[current_image].src;\nelse\nwindow.document.map.src = imsg[current_image].src;\nif (playing) {\nwindow.clearTimeout(timerID);\ntimerID = window.setTimeout(\"animate_image()\", speed, \"JavaScript\");\n}\n}\n\n\nfunction changeimage(dest){\n\n   switch (dest)\n   {\n\tcase \"+\":\n                if (current_image==count-1) { current_image=1;} else {current_image=current_image + 1;};\n            if (isNS == 1)\n                window.document.content.document.map.src = imsg[current_image].src;\n            else  \n    \t\t    window.document.map.src = imsg[current_image].src;\n    \t\tbreak;\n\n\tcase \"-\":\n                if (current_image==1) { current_image=count-1;} else {current_image=current_image - 1;}; \n            if (isNS == 1)\n                window.document.content.document.map.src = imsg[current_image].src;\n            else\n    \t\t    window.document.map.src = imsg[current_image].src;\n    \t\tbreak;\n        \n        case \"b\":\n        \tcurrent_image = 1;\n            if (isNS == 1)\n               window.document.content.document.map.src = imsg[1].src;\n            else\n    \t\t   window.document.map.src = imsg[1].src;\n    \t\tbreak;\n\n        case \"e\":\n        \tcurrent_image = count-1;\n            if (isNS == 1)\n                window.document.content.document.map.src = imsg[count-1].src;\n            else\n    \t\t    window.document.map.src = imsg[count-1].src;\n    \t\tbreak;\n\n\tdefault:\n        \tif (isNS == 1)\n                window.document.content.document.map.src = imsg[1].src;\n            else\n                window.document.map.src = imsg[1].src;\n    }\n\n}\n\n\nfunction forward_image() {changeimage(\"+\");}\nfunction backward_image() {changeimage(\"-\");}\nfunction first_image() {changeimage(\"b\");}\nfunction last_image() {changeimage(\"e\");}\nfunction stop_play_images() {playing=false;}\n\nfunction continue_play_images() {\nplaying = true;\ntimerID = window.setTimeout(\"animate_image()\", speed, \"JavaScript\");\n}\n\n\nfunction faster() {\n\n speed = speed - 50;\n if (speed <10) {speed=10;}\n}\n\nfunction slower() { \nspeed = speed + 50;\n\n}\n"
