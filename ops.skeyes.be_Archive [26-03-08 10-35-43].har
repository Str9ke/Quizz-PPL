            "text": "\n\n\n\n<head>\n\t<link href=\"Styles/master.css\" rel=\"stylesheet\" type=\"text/css\">\n\t\n\t<script src=\"resources/javascript/animation.js\"></script>\n\t<script type='text/javascript'> \n\tfunction hidediv() { \n\t\tif (document.getElementById) { // DOM3 = IE5, NS6 \n\t\t\tdocument.getElementById('hideShow').style.visibility = 'hidden'; \n\t\t} else { \n\t\t\tif (document.layers) { // Netscape 4 \n\t\t\t\tdocument.hideShow.visibility = 'hidden'; \n\t\t\t} else { // IE 4 \n\t\t\t\tdocument.all.hideShow.style.visibility = 'hidden'; \n\t\t\t} \n\t\t} \n\t} \n\t\n\tfunction showdiv() { \n\t\tif (document.getElementById) { // DOM3 = IE5, NS6 \n\t\t\tdocument.getElementById('hideShow').style.visibility = 'visible'; \n\t\t} else { \n\t\t\tif (document.layers) { // Netscape 4 \n\t\t\t\tdocument.hideShow.visibility = 'visible'; \n\t\t\t} else { // IE 4 \n\t\t\t\tdocument.all.hideShow.style.visibility = 'visible'; \n\t\t\t} \n\t\t} \n\t} \n\t</script>\n\t\n\t<script type=\"text/javascript\"> \n\t<!-- \n\tfunction showhide(id){ \n\t\tif (document.getElementById){ \n\t\t\tobj = document.getElementById(id); \n\t\t\tif (obj.style.display == \"none\"){ \n\t\t\t\tobj.style.display = \"\"; \n\t\t\t} else { \n\t\t\t\tobj.style.display = \"none\"; \n\t\t\t} \n\t\t} \n\t} \n\t//--> \n\t</script>\n\t\n\t\n\t\t<script>\n\t\t\tfunction displayRoadButton() {\n\t\t\t\tvar nav = window.navigator.userAgent;\n\t\t\t\tif ((pos=nav.indexOf(\"MSIE\"))!=-1){\n\t\t\t\t\tif((version = nav.charAt(eval(pos+5)))<=6) {\n\t\t\t\t\t\treturn;\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tif (document.getElementById(\"road_button\")) {\n\t\t\t\t\tdocument.getElementById(\"road_button\").style.display=\"inline\";\t\t\t\t\t\n\t\t\t\t}\t\n\t\t\t\treturn;\n\t\t\t}\n\t\t\tfunction changeRoads() {\n\t\t\t\tvar value = document.getElementById('roads').style.display;\n\t\t\t\t(value=='none') ? document.getElementById('roads').style.display='block' : document.getElementById('roads').style.display='none';\n\t\t\t}\n\t\t</script>\n\t\n\t\n\t\n\t\n\t<script type='text/javascript'>\rfunction preloadImages(){\rimsg[1] = new Image();\rimsg[1].onload = load_check;\rimsg[1].src = '/remotesensing/radar/max/RADSRV260308075505.MAX3061.gif';\r\rimsg[2] = new Image();\rimsg[2].onload = load_check;\rimsg[2].src = '/remotesensing/radar/max/RADSRV260308080005.MAX3063.gif';\r\rimsg[3] = new Image();\rimsg[3].onload = load_check;\rimsg[3].src = '/remotesensing/radar/max/RADSRV260308080505.MAX3065.gif';\r\rimsg[4] = new Image();\rimsg[4].onload = load_check;\rimsg[4].src = '/remotesensing/radar/max/RADSRV260308081005.MAX3067.gif';\r\rimsg[5] = new Image();\rimsg[5].onload = load_check;\rimsg[5].src = '/remotesensing/radar/max/RADSRV260308081505.MAX3069.gif';\r\rimsg[6] = new Image();\rimsg[6].onload = load_check;\rimsg[6].src = '/remotesensing/radar/max/RADSRV260308082005.MAX3071.gif';\r\rimsg[7] = new Image();\rimsg[7].onload = load_check;\rimsg[7].src = '/remotesensing/radar/max/RADSRV260308082505.MAX3073.gif';\r\rimsg[8] = new Image();\rimsg[8].onload = load_check;\rimsg[8].src = '/remotesensing/radar/max/RADSRV260308083005.MAX3075.gif';\r\rimsg[9] = new Image();\rimsg[9].onload = load_check;\rimsg[9].src = '/remotesensing/radar/max/RADSRV260308083505.MAX3077.gif';\r\rimsg[10] = new Image();\rimsg[10].onload = load_check;\rimsg[10].src = '/remotesensing/radar/max/RADSRV260308084005.MAX3079.gif';\r\rimsg[11] = new Image();\rimsg[11].onload = load_check;\rimsg[11].src = '/remotesensing/radar/max/RADSRV260308084505.MAX3081.gif';\r\rimsg[12] = new Image();\rimsg[12].onload = load_check;\rimsg[12].src = '/remotesensing/radar/max/RADSRV260308085005.MAX3082.gif';\r\rimsg[13] = new Image();\rimsg[13].onload = load_check;\rimsg[13].src = '/remotesensing/radar/max/RADSRV260308085505.MAX3084.gif';\r\rimsg[14] = new Image();\rimsg[14].onload = load_check;\rimsg[14].src = '/remotesensing/radar/max/RADSRV260308090005.MAX3086.gif';\r\rimsg[15] = new Image();\rimsg[15].onload = load_check;\rimsg[15].src = '/remotesensing/radar/max/RADSRV260308090505.MAX3088.gif';\r\rimsg[16] = new Image();\rimsg[16].onload = load_check;\rimsg[16].src = '/remotesensing/radar/max/RADSRV260308091005.MAX3090.gif';\r\rimsg[17] = new Image();\rimsg[17].onload = load_check;\rimsg[17].src = '/remotesensing/radar/max/RADSRV260308091505.MAX3092.gif';\r\rimsg[18] = new Image();\rimsg[18].onload = load_check;\rimsg[18].src = '/remotesensing/radar/max/RADSRV260308092005.MAX3094.gif';\r\r}\r</script>\r\n</head>\n\n\n\n\t<body onload=\"preloadImages(); displayRoadButton()\" style=\"background-color: #ffffff;\">\n\n\n\n\t<table>\n\t\t<tr>\n\t\t\t<td>\n\t\t\t\t<div style='padding: 0; display: block; border: solid #80add6 2px; background-color: #dce8f4; text-align: center'>\n\t\t\t\t\t<span class=\"pageTitle\" style=\"padding-left:0\">\t\n\t\t\t\t\t\t\n\t\t\t\t\t\t\tRemote Sensing&nbsp;-\n\t\t\t\t\t\t\tRADAR Jabbeke\n\t\t\t\t\t\t \n\t\t\t\t\t\t\n\t\t\t\t\t</span>\n\t\t\t\t\n\t\t\t\t\t<div style='position:relative;margin-top:0;padding-top:0'><img src='/remotesensing/radar/max/RADSRV260308092005.MAX3094.gif' title='radarmax' name='map'' border='0' align='top'><img src='resources/images/services/meteo/radar_max_roads.png' id='roads' style='position:absolute;top:1px;left:-1px;z-index:10;display:none' /><br /><div id='options' style='position: absolute; top: 480px; left: 480px'><a href='javascript:changeRoads()' id='road_button'style='display: none; height: 37; line-height:30px;width: 160px; background-color: #dce8f4; color: #009ee0; text-align: center;font-weight:normal;font-size:12px;font-style:italic;text-decoration:underline;'>add / remove roads</a></div>\n\t\t\n\t\t\t\t\t<div id=\"wind\">\n\t\t\t\t\t\t<a href=\"javascript:first_image()\">\n\t\t\t\t\t\t\t<img src=\"resources/images/services/meteo/animation_buttons/first.gif\" width=\"27\" height=\"37\" title=\"First image\" alt=\"First\" style=\"border:none\" />\n\t\t\t\t\t\t</a>\n\t\t\t\t\t\t<a href=\"javascript:backward_image()\">\n\t\t\t