20px 20px 20px;\n\twhite-space:pre-wrap;\n}\n\n.popup ul {\n\tlist-style-position: inside; \n\tmargin: 0px;\n\tpadding: 0px; \n\tlist-style-image: url(\"../resources/images/services/bullet_mid.gif\");\t\n}\n\n/* numwxmodel_detailinfo.jsp */\n .howintersound_list li {\n \tpadding-bottom: 1em;\n }\n \n .howintersound_list table {\n    margin-top: 1em;\n    margin-left: 3em;\n }\n \n  .howintersound_list td {\n\tline-height: 1em;\n/*     padding-left: 3em; */\n }\n \n .infoframe {\n\tborder: 1px solid #84CBB3;\n\tmargin-left: auto;\n\tmargin-right: auto;\n\tpadding: 5px 40px 5px 5px;\n\tposition: relative;\n\tmax-width: 500px;\n }\n \n@media all and (max-width: 381px) {\n\t\n\t#aismeteo img {\n\t\theight: 100px;\n\t}\n\t\n}\n\n"
