ed\n}\n.center\n{\n    FONT-SIZE: 9px;\n    COLOR: black;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: center\n}\n.sstitle\n{\n    FONT-SIZE: 10px;\n    FONT-WEIGHT: bold;\n    COLOR: #009ee0;\n    FONT-FAMILY: verdana; \n}\n.ssstitle\n{\n    FONT-SIZE: 10px;\n    COLOR: #009ee0;\n    FONT-FAMILY: verdana\n}\n.thumbnail\n{\n    FONT-SIZE: 9px;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: center;\n    TEXT-DECORATION: none\n}\n/* tags are on alphabetical order */\nA\n{\n    COLOR: #009EE0;\n    FONT-FAMILY: Verdana;\n    TEXT-DECORATION: none;\n}\n\na:visited {color: #009EE0; text-decoration: none}\na:hover {color: #df0303; text-decoration: none}\na:active {color: #df0303; text-decoration: none}\n\nBODY\n{\n    FONT-SIZE: 10px;\n    COLOR: black;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: justify;\t\n    BACKGROUND-COLOR: #ffffff;\n    margin: 0px;\n}\nTEXTAREA\n{\n    FONT-SIZE: 10px;\n\tFONT-FAMILY: verdana;    \n\t\n}\n\nH1, H2, H3, H4{\n\tFONT-FAMILY: verdana, Helvetica;\n    COLOR: #009ee0;\n    FONT-SIZE: 14px;\n    FONT-FAMILY: verdana;\n}\n\nH2{\n    FONT-SIZE: 13px;\n}\n\nH3{\n    FONT-SIZE: 12px;\n    margin-bottom: 3px;\n}\n\nH4{\n    FONT-SIZE: 11px;\n    margin-bottom: 3px;\n}\nHR\n{\n\tCOLOR: #009ee0\n}\nINPUT\n{\n    FONT-SIZE: 10px;\n    FONT-FAMILY: verdana\n}\nLI\n{\n    TEXT-INDENT: 0px\n}\nOL\n{\n    LIST-STYLE-POSITION: inside;\n    TEXT-INDENT: 0px\n}\nOPTION\n{\n    FONT-SIZE: 10px;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: left\n}\nTABLE\n{\n    FONT-SIZE: 10px;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: left\n}\nTD\n{\n    FONT-SIZE: 10px;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: left\n}\nUL\n{\n    LIST-STYLE-POSITION: inside;\n    TEXT-INDENT: 0px\n}\n\n.ralignedtd\n{\n    FONT-SIZE: 10px;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: right\n}\n\n.logoHolder{\n\tpadding-top: 10px;\n\tpadding-left: 10px;\n}\n\n.loginFormLabel{\n\tfont-family: verdana,helvetica;\n\tfont-size: 8px;\n}\n\n.smallInput, .errorMsg{\n\tfont-size: 8px;\n}\n\n.err