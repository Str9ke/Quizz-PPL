eoInfo{\n\tfont-size: 10px;\n}\n\nPRE.briefing{\n\tfont-size: 11px;\n}\n\n.iboxContainer{\n\tborder: 1px solid #80add6;\n\tpadding-left: 3px;\n}\n\n.iboxTitleWrapper{\n\tbackground-color: #CCCCCC;\n\tborder-bottom: 1px solid #80add6;\n}\n\n.iboxTitle{\t\n\tfont-weight: bold;\n\tcolor: #000000;\t\n\ttext-transform: uppercase;\n\tfont-size: 11px;\n}\n\n.iboxContent{\n\tbackground-color: #EFEFEF;\n\tfont-size: 10px;\n\tpadding-left: 3px;\n\tpadding-top: 3px;\n\tpadding-right: 3px;\n\tpadding-bottom: 3px;\n}\n\nlegend{\n\tfont-weight:bold;\n\tcolor: #B07660;\n}\n\nfieldset{\n\tmargin-bottom: 15px;\n}\n\n.fieldsettabkes{\n\twidth: 500;\n\tbackground-color: #DCE8F4;\n\ttext-align: left;\n}\n\n\nTH{\n\tfont-weight: bold;\n\tbackground-color: #EFEFEF;\n\tborder-bottom: 1px solid orange;\n\tfont-style: italic;\n}\n\n.attention\n{\n    FONT-SIZE: 10px;\n    COLOR: #ff0000;\n    FONT-FAMILY: verdana\n}\n\n.NotamDisclaimer\n{\n    FONT-SIZE: 10px;\n    COLOR: #ff0000;\n    FONT-FAMILY: verdana;\n    FONT-WEIGHT: bold;\n}\n\n/* the login is to big */\n.login {\n    font-family: verdana,helvetica;\n\tfont-size: 8px;\n\twidth: 90%;\n}  \n\n/* styles servicemeteo*/\n.dropDownMeteo {\n\tfont-family: verdana,helvetica;\n\tfont-size: 10px;\n\t}\n\n.iframe {\n    background-color: #FFFFFF;\n    font-family: verdana,helvetica;\n\tfont-size: 10px;\n\tborder: 0px;\n\twidth: 99%;\n\theight:97%;\n\t}\n.tab {\n\tfont-family: verdana,helvetica;\n\tfont-size: 9px; font-weight: bold;\n\tposition:absolute; text-align: center; \n\tborder: 2px; border-color:#009ee0;\n\tborder-style: solid;\n\tborder-bottom-style: none; \n\theight:37px;\n\twidth:160px;\n\tcolor:#009ee0;\n\tmargin:0px;\n\ttop:0px;\n\tbackground-color:#D0D3D4\n}\n.panel {\n\tbackground-color: #ffffff;\n    font-family: verdana,helvetica;\n\tfont-size: 10px;\n}\n\n.popup {\n\tbackground-color: #DCE8F4;\n}\n\t\t\n\n/*end styles servicemeteo*/\n\n/* style for the glossary page*/\n.glossary\n{\n    font-family: verdana,helvetica;\n\tfont-size: 16px;\n}\n.date\n{\n    FONT-SIZE: 10px;\n    FONT-STYLE: italic\n}\n.leftmenu\n{\n    FONT-SIZE: 10px;\n    COLOR: #009ee0;\n    FONT-FAMILY: verdana;\n    FONT-WEIGHT: bold;\n    color: #009ee0;\n    LINE-HEIGHT: 50%;\n}\n.greyleftmenu\n{\n    FONT-SIZE: 10px;\n    COLOR: gray;\n    FONT-FAMILY: verdana;\n    FONT-WEIGHT: bold;\n    color: #009ee0;\n    LINE-HEIGHT: 50%;\n}\n.leftmenu_r\n{\n    FONT-SIZE: 10px;\n    COLOR: #009ee0;\n    FONT-FAMILY: verdana;\n    color: #009ee0;\n    TEXT-INDENT: 15px;\n    LINE-HEIGHT: 50%;\n}\n.greyleftmenu_r\n{\n    FONT-SIZE: 10px;\n    COLOR: gray;\n    FONT-FAMILY: verdana;\n    color: #009ee0;\n    TEXT-INDENT: 15px;\n    LINE-HEIGHT: 50%;\n}\n.title\n{\n    FONT-SIZE: 10px;\n    TEXT-TRANSFORM: uppercase;\n    COLOR: #009ee0;\n    FONT-STYLE: normal;\n    FONT-FAMILY: verdana;\n    LETTER-SPACING: 0px\n}\n.content\n{\n\tpadding-right: 15px;\n    FONT-SIZE: 10px;\n    COLOR: black;\n    FONT-FAMILY: verdana;\n    text-align: justify;\n    LETTER-SPACING: normal;\n}\n.pibcontent\n{\n\tBORDER-STYLE: solid double;\n\tBORDER-COLOR: #b07660;\n    FONT-SIZE: 10px;\n    COLOR: black;\n    FONT-FAMILY: verdana;\n    LETTER-SPACING: normal\n}\n.notamlabel\n{\n    color: black;\n    FONT-FAMILY: verdana;\n    FONT-SIZE: 10px;\n    TEXT-ALIGN: left;\n    background-color: yellow;\n}\n.facts\n{\n    FONT-SIZE: 9px;\n    COLOR: black;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: right\n}\n.website\n{\n    FONT-SIZE: 10px;\n    COLOR: #fdf5e6;\n    FONT-FAMILY: verdana, 'Helvetica CondensedBlack';\n    LETTER-SPACING: 1px;\n    TEXT-DECORATION: none\n}\n.level1\n{\n    FONT-SIZE: 12px;\n    COLOR: slategray;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: left;\n    TEXT-DECORATION: none\n}\n.level2\n{\n    COLOR: dimgray;    \n    FONT-SIZE: 11px;\n    FONT-FAMILY: verdana;\n    TEXT-ALIGN: left;\n    TEXT-DECORATION: none\n}\n.orgtitle\n{\n    FONT-SIZE: 10px;\n    FONT-FAMILY: verdana;\n    BACKGROUND-COLOR: #c7cfd4;\n    TEXT-ALIGN