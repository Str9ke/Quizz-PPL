            "text": "/* the tags are implemented on the end of this document */\n/* please add comments when you add modifications */\n\n.overthetoptable\n{\n\tbackground-color:#DCE8F4;\n}\n.greyedoutinput\n{\n\tbackground-color: #dcdcdc;\n\tfont-family: verdana;\n}\n\n.breadcrumb\n{\n    FONT-SIZE: 10px;\n    COLOR: #8a9f93;\n    FONT-FAMILY: verdana\n}\n.bodyTile{\n\tpadding-right: 15px;\n\twidth: 100%;\n}\n\na.menu, .menudivider, .toolbarMenuDivider{\n   \tcolor: #009EDF;\n\tfont-weight: bold;\n}\n\na.menu:hover, a.menu:active {\n\tcolor: #C88544;\n}\n\na.menuitem, .menudividerWhite{\n\tcolor: #FFFFFF;\n\tfont-weight: bold;\n}\n\n.pageTitle{\n\tfont-size: 25px;\n\tfont-weight: bold;\n\tcolor: #009EDF;\n\tpadding-left: 60;\n}\n\n.toolbarMenu, .toolbarMenuDivider{\n\tfont-size: 10px;\n\ttext-transform: uppercase;\n}\n\n.treelvl3{\n\tcolor: #009EDF;\n\tfont-weight: bold;\n\tpadding-left: 0px;\n}\n\n.treelvl4{\n\tpadding-left: 20px;\n}\n\n.treelvl5{\n\tpadding-left: 40px;\n}\n\n.tabsContainer{\n\tmargin-left: 5px;\n}\n\n.frametable\n{\t\n\twidth: 100%;\n}\n\n.framecellDW\n{\t\n\tpadding: 0px;\n\tpadding-right: 0px;\n\tpadding-top: 0px;\n\tbackground-color: #DCE8F4;\n\t\n}\n\n.framecell\n{\t\n\tpadding: 13px;\n\tpadding-right: 17px;\n\tpadding-top: 0px;\n\tbackground-color: #DCE8F4;\n\t\n}\n\n.innerFrame {\n\theight: 520;\n\twidth: 685;\n\tbackground-color: #DCE8F4;\n\tborder-width: 0;\n}\n\n.innerFrameFpl {\n\theight: 559;\n\twidth: 685;\n\tbackground-color: #DCE8F4;\n\tborder-width: 0;\n}\n\n.innerFrameAip {\n\tbackground-color: #DCE8F4;\n\tborder-width: 0;\n}\n\n.innerFrameMenu {\n\theight: 427;\n\twidth: 680;\n\tbackground-color: #DCE8F4;\n\tborder-width: 0;\n}\n\n.innerFrameMenuPIB {\n\theight: 845;\n\twidth: 680;\n\tbackground-color: #DCE8F4;\n\tborder-width: 0;\n}\n\n.innerFrameMenuDW {\n\theight: 600;\n\twidth: 785;\n\tbackground-color: #DCE8F4;\n\tborder-width: 0;\n\toverflow: hidden;\n}\n\n.innerFrameDiv {\n\theight: 459;\n\twidth: 710;\n\tbackground-color: 