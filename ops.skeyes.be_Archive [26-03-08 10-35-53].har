            "text": "\n\n\n\n<head>\n\t<link href=\"Styles/master.css\" rel=\"stylesheet\" type=\"text/css\">\n\t\n\t<script src=\"resources/javascript/animation.js\"></script>\n\t<script type='text/javascript'> \n\tfunction hidediv() { \n\t\tif (document.getElementById) { // DOM3 = IE5, NS6 \n\t\t\tdocument.getElementById('hideShow').style.visibility = 'hidden'; \n\t\t} else { \n\t\t\tif (document.layers) { // Netscape 4 \n\t\t\t\tdocument.hideShow.visibility = 'hidden'; \n\t\t\t} else { // IE 4 \n\t\t\t\tdocument.all.hideShow.style.visibility = 'hidden'; \n\t\t\t} \n\t\t} \n\t} \n\t\n\tfunction showdiv() { \n\t\tif (document.getElementById) { // DOM3 = IE5, NS6 \n\t\t\tdocument.getElementById('hideShow').style.visibility = 'visible'; \n\t\t} else { \n\t\t\tif (document.layers) { // Netscape 4 \n\t\t\t\tdocument.hideShow.visibility = 'visible'; \n\t\t\t} else { // IE 4 \n\t\t\t\tdocument.all.hideShow.style.visibility = 'visible'; \n\t\t\t} \n\t\t} \n\t} \n\t</script>\n\t\n\t<script type=\"text/javascript\"> \n\t<!-- \n\tfunction showhide(id){ \n\t\tif (document.getElementById){ \n\t\t\tobj = document.getElementById(id); \n\t\t\tif (obj.style.display == \"none\"){ \n\t\t\t\tobj.style.display = \"\"; \n\t\t\t} else { \n\t\t\t\tobj.style.display = \"none\"; \n\t\t\t} \n\t\t} \n\t} \n\t//--> \n\t</script>\n\t\n\t\n\t\t<script>\n\t\t\tfunction displayRoadButton() {\n\t\t\t\tvar nav = window.navigator.userAgent;\n\t\t\t\tif ((pos=nav.indexOf(\"MSIE\"))!=-1){\n\t\t\t\t\tif((version = nav.charAt(eval(pos+5)))<=6) {\n\t\t\t\t\t\treturn;\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tif (document.getElementById(\"road_button\")) {\n\t\t\t\t\tdocument.getElementById(\"road_button\").style.display=\"inline\";\t\t\t\t\t\n\t\t\t\t}\t\n\t\t\t\treturn;\n\t\t\t}\n\t\t\tfunction changeRoads() {\n\t\t\t\tvar value = document.getElementById('roads').style.display;\n\t\t\t\t(value=='none') ? document.getElementById('roads').style.display='block' : document.getElementById('roads').style.display='none';\n\t\t\t}\n\t\t</script>\n\t\n\t\n\t\n\t\n\t<script type='text/javascript'>\rfunction preloadImages(){\rimsg[1] = new Image();\rimsg[1].onload = load_check;\rimsg[1].src = '/remotesensing/radar/plip/METSRV202603080755.PLIP.jpg';\r\rimsg[2] = new Image();\rimsg[2].onload = load_check;\rimsg[2].src = '/remotesensing/radar/plip/METSRV202603080800.PLIP.jpg';\r\rimsg[3] = new Image();\rimsg[3].onload = load_check;\rimsg[3].src = '/remotesensing/radar/plip/METSRV202603080805.PLIP.jpg';\r\rimsg[4] = new Image();\rimsg[4].onload = load_check;\rimsg[4].src = '/remotesensing/radar/plip/METSRV202603080810.PLIP.jpg';\r\rimsg[5] = new Image();\rimsg[5].onload = load_check;\rimsg[5].src = '/remotesensing/radar/plip/METSRV202603080815.PLIP.jpg';\r\rimsg[6] = new Image();\rimsg[6].onload = load_check;\rimsg[6].src = '/remotesensing/radar/plip/METSRV202603080820.PLIP.jpg';\r\rimsg[7] = new Image();\rimsg[7].onload = load_check;\rimsg[7].src = '/remotesensing/radar/plip/METSRV202603080825.PLIP.jpg';\r\rimsg[8] = new Image();\rimsg[8].onload = load_check;\rimsg[8].src = '/remotesensing/radar/plip/METSRV202603080830.PLIP.jpg';\r\rimsg[9] = new Image();\rimsg[9].onload = load_check;\rimsg[9].src = '/remotesensing/radar/plip/METSRV202603080835.PLIP.jpg';\r\rimsg[10] = new Image();\rimsg[10].onload = load_check;\rimsg[10].src = '/remotesensing/radar/plip/METSRV202603080840.PLIP.jpg';\r\rimsg[11] = new Image();\rimsg[11].onload = load_check;\rimsg[11].src = '/remotesensing/radar/plip/METSRV202603080845.PLIP.jpg';\r\rimsg[12] = new Image();\rimsg[12].onload = load_check;\rimsg[12].src = '/remotesensing/radar/plip/METSRV202603080850.PLIP.jpg';\r\rimsg[13] = new Image();\rimsg[13].onload = load_check;\rimsg[13].src = '/remotesensing/radar/plip/METSRV202603080855.PLIP.jpg';\r\rimsg[14] = new Image();\rimsg[14].onload = load_check;\rimsg[14].src = '/remotesensing/radar/plip/METSRV202603080900.PLIP.jpg';\r\rimsg[15] = new Image();\rimsg[15].onload = load_check;\rimsg[15].src = '/remotesensing/